{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "types": ["astro/client"],
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  },
  "exclude": ["node_modules", "dist", "scripts"]
}
