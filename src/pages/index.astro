---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Layout/Header.astro";
import Footer from "../components/Layout/Footer.astro";
import WebsitePageSections from "../components/Pages/WebsitePageSections.astro";

import {
  getWebsitePageBySlug,
  HOME_CMS_SLUG,
  ROOT_WEBSITE_LOCALE,
} from "../lib/sanity";
import { generateFAQSchema, generateWebPageSchema } from "../lib/schema";
import { LOCALES, WEBSITE_PAGE_COPY } from "../lib/i18n";
import { localeIdForWebsiteLocale } from "../lib/i18n/websiteLocaleBridge";

const homePage = await getWebsitePageBySlug(
  HOME_CMS_SLUG[ROOT_WEBSITE_LOCALE],
  ROOT_WEBSITE_LOCALE,
);
if (!homePage) {
  throw new Error(
    `Sanity: home page not found for ${ROOT_WEBSITE_LOCALE} slug "${HOME_CMS_SLUG[ROOT_WEBSITE_LOCALE]}" — check Website Page (intl).`,
  );
}

const localeId = localeIdForWebsiteLocale(ROOT_WEBSITE_LOCALE);
const htmlLang = LOCALES[localeId].htmlLang;
const pageCopy = WEBSITE_PAGE_COPY[localeId];

function formatDisplayDate(iso: string | undefined) {
  if (!iso) return null;
  try {
    return new Intl.DateTimeFormat(htmlLang || "en", {
      dateStyle: "medium",
    }).format(new Date(iso));
  } catch {
    return iso;
  }
}

const createdDisplay = formatDisplayDate(homePage.createdAt);
const updatedDisplay = formatDisplayDate(homePage.updatedAt);
const showPageDates = Boolean(homePage.createdAt || homePage.updatedAt);

const webPageSchema = generateWebPageSchema(homePage);

const faqSchemas = homePage.sections
  .filter((section) => section.kind === "faqComponent")
  .map((section) => generateFAQSchema(section))
  .filter(Boolean);

const seoData = {
  title:
    homePage.seo?.seoTitle ||
    "PP Casinos Info - Best Online Casinos Accepting PayPal",
  description:
    homePage.seo?.seoDescription ||
    "Expert reviews of the best PayPal casinos online. Find trusted casinos that accept PayPal deposits and withdrawals with exclusive bonuses.",
  canonical: "/",
  openGraph: {
    title: homePage.seo?.seoTitle,
    description: homePage.seo?.seoDescription,
    type: "website",
  },
};
---

<BaseLayout seo={seoData} lang={htmlLang}>
  <Header locale={ROOT_WEBSITE_LOCALE} localizedSlugs={homePage.localizedSlugs} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  {faqSchemas.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchemas)} />
  )}
  <main id="main-content" class="flex-1 pt-12 my-32">
    <div class="mx-auto w-full max-w-5xl px-4 pb-16 sm:px-6 lg:px-8">
      <div
        class="overflow-hidden rounded-xl border border-slate-200/90 bg-slate-50/70 shadow-sm dark:border-zinc-700 dark:bg-zinc-900/55"
      >
        {showPageDates ? (
          <div
            class="flex justify-end border-b border-slate-200/70 bg-white/60 px-4 py-2.5 font-roboto text-xs leading-snug text-slate-600 dark:border-zinc-700/70 dark:bg-zinc-900/50 dark:text-slate-400"
          >
            <div class="text-right">
              {homePage.createdAt ? (
                <div>
                  <span class="font-medium text-slate-500 dark:text-slate-500"
                    >{pageCopy.created}</span
                  >{" "}
                  <time datetime={homePage.createdAt}>{createdDisplay}</time>
                </div>
              ) : null}
              {homePage.updatedAt ? (
                <div class:list={{ "mt-1": Boolean(homePage.createdAt) }}>
                  <span class="font-medium text-slate-500 dark:text-slate-500"
                    >{pageCopy.updated}</span
                  >{" "}
                  <time datetime={homePage.updatedAt}>{updatedDisplay}</time>
                </div>
              ) : null}
            </div>
          </div>
        ) : null}
        <WebsitePageSections sections={homePage.sections} locale={ROOT_WEBSITE_LOCALE} />
      </div>
    </div>
  </main>
  <Footer locale={ROOT_WEBSITE_LOCALE} />
</BaseLayout>
