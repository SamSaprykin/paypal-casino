---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Layout/Header.astro";
import Footer from "../components/Layout/Footer.astro";
import WebsitePageSections from "../components/Pages/WebsitePageSections.astro";

import {
  getWebsitePageBySlug,
  HOME_CMS_SLUG,
  ROOT_WEBSITE_LOCALE,
} from "../lib/sanity";
import { generateFAQSchema, generateWebPageSchema } from "../lib/schema";
import { LOCALES } from "../lib/i18n";
import { localeIdForWebsiteLocale } from "../lib/i18n/websiteLocaleBridge";

const homePage = await getWebsitePageBySlug(
  HOME_CMS_SLUG[ROOT_WEBSITE_LOCALE],
  ROOT_WEBSITE_LOCALE,
);
if (!homePage) {
  throw new Error(
    `Sanity: home page not found for ${ROOT_WEBSITE_LOCALE} slug "${HOME_CMS_SLUG[ROOT_WEBSITE_LOCALE]}" — check Website Page (intl).`,
  );
}

const htmlLang = LOCALES[localeIdForWebsiteLocale(ROOT_WEBSITE_LOCALE)].htmlLang;

const webPageSchema = generateWebPageSchema(homePage);

const faqSchemas = homePage.sections
  .filter((section) => section.kind === "faqComponent")
  .map((section) => generateFAQSchema(section))
  .filter(Boolean);

const seoData = {
  title:
    homePage.seo?.seoTitle ||
    "PP Casinos Info - Best Online Casinos Accepting PayPal",
  description:
    homePage.seo?.seoDescription ||
    "Expert reviews of the best PayPal casinos online. Find trusted casinos that accept PayPal deposits and withdrawals with exclusive bonuses.",
  canonical: "/",
  openGraph: {
    title: homePage.seo?.seoTitle,
    description: homePage.seo?.seoDescription,
    type: "website",
  },
};
---

<BaseLayout seo={seoData} lang={htmlLang}>
  <Header locale={ROOT_WEBSITE_LOCALE} localizedSlugs={homePage.localizedSlugs} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  {faqSchemas.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchemas)} />
  )}
  <WebsitePageSections sections={homePage.sections} locale={ROOT_WEBSITE_LOCALE} />
  <Footer locale={ROOT_WEBSITE_LOCALE} />
</BaseLayout>
