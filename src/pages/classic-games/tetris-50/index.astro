---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Layout/Header.astro";
import Footer from "../../../components/Layout/Footer.astro";
import GamePageShell from "../../../components/Layout/GamePageShell.astro";
import ClassicGameTetrisEditorial from "../../../components/Layout/ClassicGameTetrisEditorial.astro";
import TetrisStyleEditorialCard from "../../../components/Layout/TetrisStyleEditorialCard.astro";
import Tetris from "../../../components/Games/Tetris.jsx";
import TetrisComparison from "../../../components/Games/TetrisComparison.astro";
import {
  generateWebPageSchema,
  generateBreadcrumbSchema,
  generateClassicGameBreadcrumbs,
} from "../../../lib/schema";

const seoData = {
  title: "Tetris 50 | 50-Line Sprint (Browser Game)",
  description:
    "Tetris 50: clear 50 lines as fast as you can. Free browser game with the same controls and sounds as our classic Tetris.",
  canonical: "/classic-games/tetris-50/",
  openGraph: {
    title: "Tetris 50 | Paypalcasinoguides",
    description:
      "A 50-line sprint mode—clear fifty lines to win. Entertainment only, not real-money play.",
    type: "website",
  },
  keywords: ["tetris", "tetris 50", "line sprint", "puzzle game", "browser game"],
};

const pageData = {
  name: "Tetris 50",
  title: "Tetris 50",
  slug: "classic-games/tetris-50",
  description:
    "Fifty-line sprint: clear 50 total lines to win. Same Tetris feel with a clear goal.",
  sys: {
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  },
};

const webPageSchema = generateWebPageSchema(pageData);
const breadcrumbSchema = generateBreadcrumbSchema(
  generateClassicGameBreadcrumbs("Tetris 50"),
);
---

<BaseLayout seo={seoData}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>

  <main class="flex-1 w-full min-w-0">
    <GamePageShell title="Tetris 50" mode="tetris-50">
      <p class="!mb-0" slot="intro" id="play">
        Sprint mode: your goal is to clear <strong>50 lines</strong> in total. You
        can still top out if the stack reaches the top — so plan ahead. Free to
        play, for fun only, <strong>not</strong> gambling.
      </p>
      <Tetris lineGoal={50} client:load />
    </GamePageShell>
    <TetrisComparison />
    <ClassicGameTetrisEditorial
      eyebrow="Puzzle · Sprint · Free"
      heroTitle="Tetris 50"
      heroEmphasis="fifty lines to win"
      heroSubtitle="Same controls and sound as our classic Tetris, but the round ends when you clear 50 total lines — a clear finish line. Not real-money play."
      decor="sprint"
    >
      <ol class="!mb-0" slot="howToPlay">
        <li>
          <strong>Start</strong>: with the board ready, press
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >Space</kbd
          > or
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >Enter</kbd
          > to begin (also works after <strong>game over</strong> to restart).
        </li>
        <li>
          <strong>Move</strong> pieces with
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >←</kbd
          >
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >→</kbd
          >, <strong>rotate</strong> with
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >↑</kbd
          >, <strong>soft drop</strong> with
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >↓</kbd
          >, and <strong>hard drop</strong> with
          <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >Space</kbd
          >. <kbd
            class="px-1.5 py-0.5 bg-white border border-[#c5d4e0] rounded text-sm font-mono"
            >P</kbd
          > <strong>pauses</strong>.
        </li>
        <li>
          <strong>Win</strong> the sprint when the <strong>line counter</strong> reaches
          <strong>50</strong> — you can still <strong>lose</strong> if the stack
          hits the top, so the ceiling still matters.
        </li>
        <li>
          Toggle <strong>Sound</strong> in the game chrome. There is
          <strong>no</strong> stake, prize, or account — only a timer and a line
          count for your run.
        </li>
      </ol>

      <TetrisStyleEditorialCard
        title="Fifty lines instead of “forever”"
        colSpan="full"
        icon="50"
        accentLine="cyan"
        variant="default"
      >
        <p>
          Our classic <a
            class="!text-[#155e99] font-semibold"
            href="/classic-games/tetris/">Tetris</a
          > is open-ended: pieces fall, lines vanish, and the game only stops
          when the stack breaches the top or you step away. <strong
            >Tetris 50</strong
          > is the same engine with a different contract: the round ends when
          you have cleared a fixed total of <strong>fifty lines</strong> — a
          clean goal for a coffee break, with no wagers, tickets, or payouts.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="What a numeric goal changes"
        colSpan="half"
        icon="🎯"
        accentLine="purple"
        variant="default"
      >
        <p>
          A <strong>line counter</strong> shifts how you play the middle of the
          well. In a fifty-line run, you can see the endgame: in the
          thirties and forties, every big clear feels like a lap closer to the
          tape. <strong>Topout</strong> is still real — sloppy stacking does not
          get a pass because a finish line exists.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Time-boxed practice, not a house edge"
        colSpan="half"
        icon="⏱️"
        accentLine="gold"
        variant="default"
      >
        <p>
          This mode is for <strong>measurable</strong> goals and personal
          bests — it is <em>not</em> a competition against a house edge or
          real-money gambling. The comparison table <strong>above</strong> matches
          endless and sprint so you always know which mode you opened.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Line up another run"
        variant="accent"
        colSpan="full"
        accentLine="gold"
        icon="▬"
      >
        <p class="!mb-5">
          When the fiftieth line clears, enjoy the small win, reset for another
          shuffle, and get back to your day — that is the design.
        </p>
        <a
          href="#play"
          class="classic-game-editorial-cta-sm inline-block font-['Space_Mono','Courier_New',monospace] text-[.82rem] sm:text-[.87rem] tracking-[.08em] uppercase no-underline py-2.5 px-5 border-[1.5px] border-[#00cfcf] text-white bg-gradient-to-r from-[#00cfcf] via-[#00cfcf] to-[#10b8c8] rounded-md font-bold shadow-[0_2px_10px_0_#b6f1ec3f]"
          >Jump to the sprint →</a
        >
      </TetrisStyleEditorialCard>
    </ClassicGameTetrisEditorial>
  </main>

  <Footer />
</BaseLayout>
