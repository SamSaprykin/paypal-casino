---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Layout/Header.astro";
import Footer from "../../../components/Layout/Footer.astro";
import GamePageShell from "../../../components/Layout/GamePageShell.astro";
import ClassicGameTetrisEditorial from "../../../components/Layout/ClassicGameTetrisEditorial.astro";
import TetrisStyleEditorialCard from "../../../components/Layout/TetrisStyleEditorialCard.astro";
import RussianSolitaire from "../../../components/Games/RussianSolitaire.jsx";
import {
  generateWebPageSchema,
  generateBreadcrumbSchema,
  generateClassicGameBreadcrumbs,
} from "../../../lib/schema";

const seoData = {
  title: "Russian Solitaire Online | Free Browser Game",
  description:
    "Play Russian Solitaire: build down in the same suit, no stock, hidden cards flip when uncovered, foundations A–K. Free, for fun only.",
  canonical: "/classic-games/russian/",
  openGraph: {
    title: "Russian Solitaire | Paypalcasinoguides",
    description:
      "Yukon-style solitaire with same-suit building and no waste pile. Not real-money play.",
    type: "website",
  },
  keywords: [
    "russian solitaire",
    "yukon",
    "solitaire",
    "patience",
    "browser game",
  ],
};

const pageData = {
  name: "Russian Solitaire",
  title: "Russian Solitaire",
  slug: "classic-games/russian",
  description:
    "Russian solitaire: same-suit columns, 52 cards in seven piles, no stock or waste.",
  sys: {
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  },
};

const webPageSchema = generateWebPageSchema(pageData);
const breadcrumbSchema = generateBreadcrumbSchema(
  generateClassicGameBreadcrumbs("Russian"),
);
---

<BaseLayout seo={seoData}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>

  <main class="flex-1 w-full min-w-0">
    <GamePageShell
      title="Russian Solitaire"
      companionLink={{
        href: "/classic-games/yukon/",
        label: "Yukon",
        sub: "Alternate colors",
      }}
    >
      <p class="!mb-0" slot="intro" id="play">
        A tougher Yukon-style game: the tableau goes down in the <strong>same
        suit</strong>, you start with some cards face down, and there is
        <strong>no</strong> way to take cards from foundations back to the
        table. <strong>Not</strong> real-money play.
      </p>
      <RussianSolitaire client:load />
    </GamePageShell>
    <ClassicGameTetrisEditorial
      eyebrow="Cards · Patience · Free"
      heroTitle="Russian solitaire"
      heroEmphasis="same-suit on the tableau"
      heroSubtitle="No stock or waste, seven long columns, and foundations to A–K — but every rank looks for the next in suit, not alternating color. Entertainment only."
      decor="cards"
    >
      <ol class="!mb-0" slot="howToPlay">
        <li>
          <strong>Goal</strong>: move all cards to the four <strong>foundations</strong>,
          one suit each, building <strong>ace up to king</strong> by <strong>rank</strong>.
        </li>
        <li>
          <strong>Tableau</strong>: build <strong>down in the same suit</strong> (e.g. 5♣ on
          6♣). You can move a face-up <em>group</em> in one go when the
          <em>lead</em> card (the one that will touch the pile you build on) is
          the right next rank in that suit; cards above it in the hand need not
          be ordered. As in Yukon, the deal puts some cards face down until you
          free them.
        </li>
        <li>
          <strong>Empty columns</strong> only take a <strong>King</strong> (or a valid stack
          whose contact card is a King) on the bare column.
        </li>
        <li>
          <strong>Double-click</strong> the column bottom to try
          <strong>auto-sending</strong> to a foundation. <strong>Hint</strong> shows
          a legal move; <strong>Undo</strong> steps back. <strong>Time</strong> and
          <strong>Moves</strong> are for your run only. Once a card sits on a
          <strong>foundation</strong> in this build, it <strong>stays</strong> there — no
          take-backs to the table.
        </li>
        <li>
          <strong>New game</strong> for a new shuffle. <strong>Not</strong> gambling: no
          buy-in, no prize, no account.
        </li>
      </ol>

      <TetrisStyleEditorialCard
        title="Why Russian is steeper than Yukon"
        colSpan="full"
        icon="🃏"
        accentLine="cyan"
        variant="default"
      >
        <p>
          Russian and Yukon share the <strong>no stock</strong> deal and
          <strong>group</strong> moves, but the tableau rule is the squeeze:
          you look for the next card <em>in the same suit</em>, not alternating
          red and black. That cuts the number of legal landing places and is why
          many players find it harder than Yukon — and why finishing feels so
          sharp. If you want alternating colors and optional foundation
          take-backs, our{" "}
          <a class="!text-[#155e99] font-semibold" href="/classic-games/yukon/"
            >Yukon</a
          > page is the family match.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Face-down cards and the rhythm of the deal"
        colSpan="half"
        icon="🎴"
        accentLine="purple"
        variant="default"
      >
        <p>
          The first column is a single open card; the wider columns mix hidden
          and visible bottom rows. As you free covered cards, new ones flip
          into play, expanding your options a little at a time.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Free play, not a pot"
        colSpan="half"
        icon="🎛️"
        accentLine="cyan"
        variant="default"
      >
        <p>
          There is <strong>no</strong> jackpot beyond a clear board — the same
          “got it” moment as a hard crossword. If you are browsing casino
          reviews here, use this as a break where only patience is on the line.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Try Yukon next"
        variant="accent"
        colSpan="full"
        accentLine="gold"
        icon="→"
      >
        <p class="!mb-5">
          Same seven-column look, <strong>alternating</strong> colors, and
          rules that let you <strong>move a foundation card</strong> back to
          the table when the rule set allows — hop to{" "}
          <a
            class="!text-[#155e99] font-semibold"
            href="/classic-games/yukon/">Yukon solitaire</a
          > for that variant.
        </p>
        <a
          href="#play"
          class="classic-game-editorial-cta-sm inline-block font-['Space_Mono','Courier_New',monospace] text-[.82rem] sm:text-[.87rem] tracking-[.08em] uppercase no-underline py-2.5 px-5 border-[1.5px] border-[#00cfcf] text-white bg-gradient-to-r from-[#00cfcf] via-[#00cfcf] to-[#10b8c8] rounded-md font-bold shadow-[0_2px_10px_0_#b6f1ec3f]"
          >Back to the game →</a
        >
      </TetrisStyleEditorialCard>
    </ClassicGameTetrisEditorial>
  </main>

  <Footer />
</BaseLayout>
