---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Layout/Header.astro";
import Footer from "../../../components/Layout/Footer.astro";
import GamePageShell from "../../../components/Layout/GamePageShell.astro";
import ClassicGameTetrisEditorial from "../../../components/Layout/ClassicGameTetrisEditorial.astro";
import TetrisStyleEditorialCard from "../../../components/Layout/TetrisStyleEditorialCard.astro";
import Yukon from "../../../components/Games/Yukon.jsx";
import {
  generateWebPageSchema,
  generateBreadcrumbSchema,
  generateClassicGameBreadcrumbs,
} from "../../../lib/schema";

const seoData = {
  title: "Yukon Solitaire Online | Free Browser Game",
  description:
    "Play Yukon Solitaire: no stock pile, move groups with one matching card, build foundations A–K by suit. Free in your browser, for fun only.",
  canonical: "/classic-games/yukon/",
  openGraph: {
    title: "Yukon Solitaire | Paypalcasinoguides",
    description:
      "Free Yukon solitaire: seven columns, foundations, foundation-to-tableau moves. Not real-money play.",
    type: "website",
  },
  keywords: ["yukon solitaire", "solitaire", "cards", "patience", "free game", "browser game"],
};

const pageData = {
  name: "Yukon Solitaire",
  title: "Yukon Solitaire",
  slug: "classic-games/yukon",
  description:
    "Yukon solitaire: all cards in the tableau, build foundations, optional backtrack from foundations.",
  sys: {
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  },
};

const webPageSchema = generateWebPageSchema(pageData);
const breadcrumbSchema = generateBreadcrumbSchema(
  generateClassicGameBreadcrumbs("Yukon"),
);
---

<BaseLayout seo={seoData}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>

  <main class="flex-1 w-full min-w-0">
    <GamePageShell
      title="Yukon Solitaire"
      companionLink={{
        href: "/classic-games/russian/",
        label: "Russian",
        sub: "Same suit on tableau",
      }}
    >
      <p class="!mb-0" slot="intro" id="play">
        A Klondike-style variant with <strong>no</strong> stock: every card starts
        in seven columns, you may drag a <em>face-up run</em> as long as the
        lead card (the one you place) fits, and you can take cards back from
        foundations when it helps. <strong>Not</strong> real-money play.
      </p>
      <Yukon client:load />
    </GamePageShell>
    <ClassicGameTetrisEditorial
      eyebrow="Cards · Patience · Free"
      heroTitle="Yukon solitaire"
      heroEmphasis="all cards on the table"
      heroSubtitle="No stock, no waste — 52 cards in seven columns from the first deal, foundations to A–K, and a lead-card rule for moving blocks. For fun only."
      decor="cards"
    >
      <ol class="!mb-0" slot="howToPlay">
        <li>
          <strong>Goal</strong>: build all four <strong>foundations</strong> from ace to king, one
          suit per pile. The tableau is built <strong>down</strong> in
          <strong>alternating red and black</strong> (like Klondike), but a face-up
          <em>group</em> can move in one go when the <em>first</em> card of that
          group is the one that may legally sit on the target — the cards
          above it in the hand do <strong>not</strong> need to be in sequence.
        </li>
        <li>
          <strong>Select a card</strong> (or the last card in a run you want) to
          <strong>highlight a stack</strong> from that point up. Tap a
          <strong>foundation</strong> or <strong>column</strong> to move. An
          <strong>empty</strong> column only accepts a
          <strong>King</strong> (or a group whose contact card is a King), same as
          many patience games.
        </li>
        <li>
          <strong>Foundations</strong>: the top card of a foundation can
          <strong>return to the tableau</strong> in this build — select the
          foundation, then tap a column where the card fits, when you need to
          unblock a line.
        </li>
        <li>
          <strong>Double-click</strong> the bottom card of a column to
          <strong>auto-play</strong> to a foundation when the rules allow.
          <strong>Hint</strong> shows a legal move; <strong>Undo</strong> steps
          back. The toolbar shows <strong>Time</strong> and
          <strong>Moves</strong> for your session only.
        </li>
        <li>
          <strong>New game</strong> shuffles a fresh deal. This is
          <strong>not</strong> gambling: no stake, no payout, and no account.
        </li>
      </ol>

      <TetrisStyleEditorialCard
        title="The rule that makes Yukon feel different from Klondike"
        colSpan="full"
        icon="🃏"
        accentLine="cyan"
        variant="default"
      >
        <p>
          In classic Klondike, a dragged run must already be a clean descending
          alternating-color sequence. In <strong>Yukon</strong>, you may move a
          block of face-up cards when the <em>first</em> card of the block
          (the one that sits on the target) is a legal next step — the cards
          above it in the hand can be out of order. That multiplies the number
          of lines you need to test and is why a whole column matters, not just
          the bottom card. Our page is a free, no-stake patience game for a
          quiet break.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="No stock, no “bad draw”"
        colSpan="half"
        icon="♠"
        accentLine="cyan"
        variant="default"
      >
        <p>
          Every one of the fifty-two cards is in the tableau from the start.
          You cannot blame a lousy flip from the pack — there is
          <strong>no</strong> pack. What changes is the combinatorics of
          columns, gaps, and when to use foundation take-backs.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="Hint, undo, and practice"
        colSpan="half"
        icon="🎛️"
        accentLine="purple"
        variant="default"
      >
        <p>
          <strong>Hint</strong> and <strong>undo</strong> are for honest
          practice: the “right” move is sometimes one step back before three
          steps forward. Nothing here connects to a wallet or a house edge.
        </p>
      </TetrisStyleEditorialCard>

      <TetrisStyleEditorialCard
        title="A palate cleanser, not a wager"
        variant="accent"
        colSpan="full"
        accentLine="gold"
        icon="☕"
      >
        <p class="!mb-5">
          If you are here from our casino or PayPal content, this page is
          deliberate contrast: same break in the day, <em>no</em> line on a
          bank statement. For a <strong>same-suit, no take-back</strong>
          challenge in the same family, see{" "}
          <a
            class="!text-[#155e99] font-semibold"
            href="/classic-games/russian/">Russian solitaire</a
          >.
        </p>
        <a
          href="#play"
          class="classic-game-editorial-cta-sm inline-block font-['Space_Mono','Courier_New',monospace] text-[.82rem] sm:text-[.87rem] tracking-[.08em] uppercase no-underline py-2.5 px-5 border-[1.5px] border-[#00cfcf] text-white bg-gradient-to-r from-[#00cfcf] via-[#00cfcf] to-[#10b8c8] rounded-md font-bold shadow-[0_2px_10px_0_#b6f1ec3f]"
          >Back to the game →</a
        >
      </TetrisStyleEditorialCard>
    </ClassicGameTetrisEditorial>
  </main>

  <Footer />
</BaseLayout>
