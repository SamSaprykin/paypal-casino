---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Layout/Header.astro";
import Footer from "../components/Layout/Footer.astro";
import { homeHrefForLocale, ROOT_WEBSITE_LOCALE } from "../lib/sanity";
import { LOCALES, staticSitePagesCopyFor } from "../lib/i18n";
import { localeIdForWebsiteLocale } from "../lib/i18n/websiteLocaleBridge";

const locale = ROOT_WEBSITE_LOCALE;
const copy = staticSitePagesCopyFor(locale).notFound;
const id = localeIdForWebsiteLocale(locale);
const htmlLang = LOCALES[id].htmlLang;
const home = homeHrefForLocale(locale);

const meta = {
  title: copy.metaTitle,
  description: copy.metaDescription,
  type: "website" as const,
};
---

<BaseLayout seo={{ title: meta.title, description: meta.description }} lang={htmlLang}>
  <Header locale={locale} />

  <main class="flex-1 flex items-center justify-center min-h-screen bg-gradient-to-br from-primary-50 via-white to-secondary-50">
    <div class="text-center max-w-lg mx-auto">
      <div class="mb-6">
        <h1 class="text-8xl font-bold text-secondary-900">{copy.subheading}</h1>
        <p class="text-2xl font-semibold text-secondary-900 mt-4">{copy.heading}</p>
      </div>
      <p class="text-lg text-secondary-600 mb-8">
        {copy.body}
      </p>
      <div class="flex justify-center gap-4 mb-8">
        <a href={home} class="btn-primary px-6 py-3">{copy.ctaHome}</a>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>
