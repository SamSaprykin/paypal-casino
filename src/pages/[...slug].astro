---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Layout/Header.astro";
import Footer from "../components/Layout/Footer.astro";
import WebsitePageSections from "../components/Pages/WebsitePageSections.astro";
import PageByline from "../components/Pages/PageByline.astro";

import {
  getWebsitePageBySlug,
  getWebsitePageStaticPaths,
  localizedHref,
  type WebsiteLocaleKey,
} from "../lib/content";
import { generateFAQSchema, generateWebPageSchema } from "../lib/schema";
import { LOCALES, WEBSITE_PAGE_COPY } from "../lib/i18n";
import { localeIdForWebsiteLocale } from "../lib/i18n/websiteLocaleBridge";

export async function getStaticPaths() {
  return getWebsitePageStaticPaths();
}

const { locale, cmsSlug } = Astro.props as {
  locale: WebsiteLocaleKey;
  cmsSlug: string;
};

const page = await getWebsitePageBySlug(cmsSlug, locale);

if (!page) {
  throw new Error(`Page not found for slug ${cmsSlug} (locale ${locale})`);
}

const webPageSchema = generateWebPageSchema(page);

const faqSchemas = page.sections
  .filter((section) => section.kind === "faqComponent")
  .map((section) => generateFAQSchema(section))
  .filter(Boolean);

const canonicalPath = localizedHref(locale, cmsSlug);

const seoData = {
  title:
    page.seo?.seoTitle ||
    `${page.name ?? "PayPal Casinos"} - PayPal Casino Reviews`,
  description:
    page.seo?.seoDescription ||
    `Learn more about ${page.name ?? "PayPal casinos"} at PayPal Casino Reviews`,
  canonical: canonicalPath,
  openGraph: {
    title: page.seo?.seoTitle,
    description: page.seo?.seoDescription,
    type: "website",
  },
};

const localeId = localeIdForWebsiteLocale(locale);
const htmlLang = LOCALES[localeId].htmlLang;
const pageCopy = WEBSITE_PAGE_COPY[localeId];

function formatDisplayDate(iso: string | undefined) {
  if (!iso) return null;
  try {
    return new Intl.DateTimeFormat(htmlLang || "en", {
      dateStyle: "medium",
    }).format(new Date(iso));
  } catch {
    return iso;
  }
}

const createdDisplay = formatDisplayDate(page.createdAt);
const updatedDisplay = formatDisplayDate(page.updatedAt);
---

<BaseLayout seo={seoData} lang={htmlLang} localeId={localeId}>
  <Header locale={locale} localizedSlugs={page.localizedSlugs} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  {
    faqSchemas.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(faqSchemas)}
      />
    )
  }
  <main id="main-content" class="flex-1 pt-12 my-32">
    <div class="mx-auto w-full max-w-5xl px-4 pb-16 sm:px-6 lg:px-8">
      <div
        class="overflow-hidden rounded-xl border border-slate-200/90 bg-slate-50/70 shadow-sm"
      >
        <PageByline
          copy={pageCopy}
          createdAt={page.createdAt}
          updatedAt={page.updatedAt}
          createdDisplay={createdDisplay}
          updatedDisplay={updatedDisplay}
          addedBy={page.addedBy}
          reviewedBy={page.reviewedBy}
        />
        <WebsitePageSections sections={page.sections} locale={locale} />
      </div>
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>
