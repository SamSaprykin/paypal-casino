---
import CasinoDetailPage from "../../../components/Pages/CasinoDetailPage.astro";
import {
  casinoUrlSegmentForLocale,
  getCasinoBySlugSanity,
  getLocalizedCasinoDetailStaticPaths,
  type WebsiteLocaleKey,
} from "../../../lib/sanity";

export async function getStaticPaths() {
  return getLocalizedCasinoDetailStaticPaths();
}

interface Props {
  locale: WebsiteLocaleKey;
  slug: string;
}

const { locale, slug } = Astro.props as Props;
const { casinoSegment } = Astro.params;

if (casinoSegment !== casinoUrlSegmentForLocale(locale)) {
  return Astro.redirect("/404/");
}

const casino = await getCasinoBySlugSanity(slug, locale);

if (!casino) {
  return Astro.redirect("/404/");
}
---

<CasinoDetailPage casino={casino} locale={locale} />
