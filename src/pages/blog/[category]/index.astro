---
import {
  BLOG_CATEGORY_LABELS,
  getAllBlogPostsSanity,
  getBlogCategoriesWithCountsSanity,
  getPostsByCategorySlugSanity,
} from "../../../lib/sanity/blogPosts";
import BlogHero from "../../../components/Pages/BlogListing/BlogHero.astro";
import BlogNav from "../../../components/Pages/BlogListing/BlogNav.astro";
import BlogListing from "../../../components/Pages/BlogListing/CardsListing.astro";

import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Layout/Header.astro";
import Footer from "../../../components/Layout/Footer.astro";
import { generateCollectionPageSchema } from "../../../lib/schema";
import { slugify } from "../../../lib/helpers";

export async function getStaticPaths() {
  return BLOG_CATEGORY_LABELS.map((categoryLabel) => ({
    params: { category: slugify(categoryLabel) },
  }));
}

const categorySlug = Astro.params.category ?? "";
const categoryLabel =
  BLOG_CATEGORY_LABELS.find((c) => slugify(c) === categorySlug.toLowerCase()) ??
  categorySlug;

const [categoryPosts, allPosts, categories] = await Promise.all([
  getPostsByCategorySlugSanity(categorySlug),
  getAllBlogPostsSanity(),
  getBlogCategoriesWithCountsSanity(),
]);

const featuredPost = allPosts.length > 0 ? allPosts[0] : null;

const shouldRenderBlogListing = !(
  categoryPosts.length === 1 &&
  featuredPost &&
  categoryPosts[0].sys.id === featuredPost.sys.id
);

const seoData = {
  title: `${categoryLabel} | PayPal Casino Blog`,
  description: `Top ${categoryLabel} articles and guides to help you make the most of your PayPal casino experience. Expert insights and reviews.`,
  canonical: `/blog/${categorySlug}/`,
  openGraph: {
    title: `${categoryLabel} Articles - PayPal Casino Blog`,
    description: `Top ${categoryLabel} articles and guides from PayPal Casino Reviews`,
    type: "website",
  },
};

const categoryItems = categoryPosts.map((post) => ({
  title: post.title,
  url: `/blog/${slugify(post.category)}/${post.slug}`,
}));

const collectionSchema = generateCollectionPageSchema(
  `${categoryLabel} | PayPal Casino Blog`,
  `Top ${categoryLabel} articles and guides to help you make the most of your PayPal casino experience.`,
  `/blog/${categorySlug}`,
  categoryItems,
);
---

<BaseLayout seo={seoData}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)}></script>
  <BlogHero featuredPost={featuredPost} />
  <BlogNav categories={categories} activeCategory={categoryLabel} />
  <BlogListing posts={categoryPosts} shouldRender={shouldRenderBlogListing} />
  <Footer />
</BaseLayout>
