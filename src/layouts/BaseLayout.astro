---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import BlockedCasinoHandler from '../components/Pages/BlockedCasinoHandler.astro';
import ReferralClickTracker from '../components/Analytics/ReferralClickTracker.astro';
import Analytics from '@vercel/analytics/astro';
import type { LocaleId } from '../lib/i18n/locales';

export interface Props {
  class?: string;
  /** BCP 47 / HTML lang */
  lang?: string;
  /** UI locale for blocked-casino modal copy */
  localeId?: LocaleId;
  seo?: {
    title?: string;
    description?: string;
    canonical?: string;
    openGraph?: {
      title?: string;
      description?: string;
      image?: string;
      type?: string;
    };
    noIndex?: boolean;
    noFollow?: boolean;
    keywords?: string[];
  };
}

const { class: className, seo, lang: langProp, localeId = "en-IE" } = Astro.props;

// Favicon configuration - using static files for better Google indexing
const htmlLang = langProp ?? "en";
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <SEO {...seo} />
    
    <!-- Primary favicon for Google and modern browsers -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    
    <!-- Apple touch icon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- Web app manifest for PWA and Google indexing -->
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#ffffff" />
    
    <meta name="google-site-verification" content="gBjZhuFwfuSu52WiwXxR7QGjuKSJydTs45TL6T7J3h0" />
    <Analytics />
  </head>
  <body class={`min-h-screen flex flex-col ${className || ''}`}>
    <slot />
    <BlockedCasinoHandler localeId={localeId} />
    <ReferralClickTracker />
  </body>
</html>
