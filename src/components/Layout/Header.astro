---
import { Menu } from "@lucide/astro";
import SubMenu from "./SubMenu.astro";
import Logo from "./Logo.astro";
import CountrySelector from "./CountrySelector.astro";
import {
  NAV_LABELS,
  ROOT_WEBSITE_LOCALE,
  getWebsitePageHrefByName,
  homeHrefForLocale,
  type WebsiteLocaleKey,
} from "../../lib/content";

interface Props {
  locale?: WebsiteLocaleKey;
  /**
   * Per-locale CMS slugs for the current page. Forwarded to the country selector so
   * switching locales lands on the equivalent page (not just the home).
   */
  localizedSlugs?: Partial<Record<WebsiteLocaleKey, string>>;
  localeHrefs?: Partial<Record<WebsiteLocaleKey, string>>;
}

const { locale = ROOT_WEBSITE_LOCALE, localizedSlugs, localeHrefs } =
  Astro.props as Props;

const labels = NAV_LABELS[locale];
const homeHref = homeHrefForLocale(locale);
const paypalCasinoHref = await getWebsitePageHrefByName("Paypal Casino", locale);
const newCasinosHref = await getWebsitePageHrefByName("New Casinos", locale);
const bonusesHref = await getWebsitePageHrefByName("Bonuses", locale);

const menuData = [
  { itemLinkRoute: homeHref, itemName: labels.onlineCasino },
  ...(paypalCasinoHref
    ? [{ itemLinkRoute: paypalCasinoHref, itemName: labels.paypalCasino }]
    : []),
  ...(newCasinosHref
    ? [{ itemLinkRoute: newCasinosHref, itemName: labels.newCasinos }]
    : []),
  ...(bonusesHref
    ? [{ itemLinkRoute: bonusesHref, itemName: labels.bonuses }]
    : []),
];
---

<nav class="fixed top-4 left-1/2 transform -translate-x-1/2 w-[calc(100vw-2rem)] lg:w-[calc(100vw-10rem)] max-w-[100rem] mx-auto bg-blue-800/95 backdrop-blur-xs text-white shadow-xl rounded-2xl z-50 transition-all duration-300">
  <div class="mx-auto px-4 lg:px-8 w-full">
    <div class="flex items-center justify-between py-2 lg:py-4 relative min-h-[60px] gap-4">
      <a href={homeHref} class="flex items-center group shrink-0">
        <Logo />
      </a>

      <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 w-[calc(100%-10rem)] justify-center">
        <ul class="flex items-center xl:space-x-2">
          {menuData.map((item, idx) => (
            <SubMenu key={idx} item={item} />
          ))}
        </ul>
      </div>

      <div class="flex items-center gap-2 lg:gap-3 shrink-0">
        <CountrySelector
          localizedSlugs={localizedSlugs}
          localeHrefs={localeHrefs}
          currentLocale={locale}
        />
        <button
          id="menu-toggle"
          class="lg:hidden text-white focus:outline-none"
          aria-label="Toggle menu"
        >
          <span id="menu-icon">
            <Menu size={24} />
          </span>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="lg:hidden overflow-hidden transition-all duration-500 ease-in-out max-h-0">
      <div class="pb-4 mt-4 md:mt-0 px-2 flex flex-col gap-4">
        <ul>
          {menuData.map((item, idx) => (
            <SubMenu key={idx} item={item} />
          ))}
        </ul>
      </div>
    </div>
  </div>
</nav>


<script is:inline>
  const toggleBtn = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  let isOpen = false;

  toggleBtn?.addEventListener("click", () => {
    isOpen = !isOpen;
    mobileMenu.style.maxHeight = isOpen
      ? mobileMenu.scrollHeight + "px"
      : "0";
    mobileMenu.style.opacity = isOpen ? "1" : "0";
  });
</script>
