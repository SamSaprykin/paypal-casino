---
import Logo from "./Logo.astro";
import GamblingTherapyLogo from "../SVG/GamblingTherapyLogo.astro";
import {
  ROOT_WEBSITE_LOCALE,
  homeHrefForLocale,
  localizedStaticPageHref,
  type WebsiteLocaleKey,
} from "../../lib/content";
import { FOOTER_COPY } from "../../lib/i18n/copies/footer";
import { localeIdForWebsiteLocale } from "../../lib/i18n/websiteLocaleBridge";

interface Props {
  locale?: WebsiteLocaleKey;
}

const { locale = ROOT_WEBSITE_LOCALE } = Astro.props as Props;
const t = FOOTER_COPY[localeIdForWebsiteLocale(locale)];
const home = homeHrefForLocale(locale);

const faqHref = localizedStaticPageHref(locale, "frequently-asked-questions");
const ratingHref = localizedStaticPageHref(locale, "rating-guidelines");

const footerNav = {
  navigationItems: [
    {
      itemName: t.classicGames,
      itemLinkRoute: localizedStaticPageHref(locale, "classic-games"),
      navigationItems: [
        {
          linkRoute: localizedStaticPageHref(locale, "classic-games"),
          linkText: t.allGamesOverview,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/tetris/",
          linkText: t.tetris,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/tetris-50/",
          linkText: t.tetris50,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/sudoku/",
          linkText: t.sudoku,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/solitaire/",
          linkText: t.solitaire,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/yukon/",
          linkText: t.yukonSolitaire,
          linkType: "internal",
        },
        {
          linkRoute: "/classic-games/russian/",
          linkText: t.russianSolitaire,
          linkType: "internal",
        },
      ],
    },
    {
      itemName: t.support,
      itemLinkRoute: "",
      navigationItems: [
        {
          linkRoute: localizedStaticPageHref(locale, "contact-us"),
          linkText: t.contactUs,
          linkType: "internal",
        },
        {
          linkRoute: faqHref,
          linkText: t.frequentlyAskedQuestions,
          linkType: "internal",
        },
        {
          linkRoute: ratingHref,
          linkText: t.casinoRatingGuide,
          linkType: "internal",
        },
        {
          linkRoute: localizedStaticPageHref(locale, "sitemap"),
          linkText: t.sitemap,
          linkType: "internal",
        },
      ],
    },
  ],
};
---

<footer class="bg-blue-950 text-white">
  <div class="mx-auto px-6 lg:px-10 py-12 max-w-5xl mx-auto">
    <div class="flex flex-col gap-6 mb-8">
      <div class="lg:col-span-1">
        <a href={home} class="flex items-center mb-4">
          <Logo />
          <span class="ml-2 text-2xl font-bold text-white">
            {t.brandName}
          </span>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12 w-full">
        {footerNav.navigationItems.map((item) => (
          <div class="text-center md:text-left">
            <h3 class="text-white font-semibold text-lg mb-6 pb-2 border-b border-white/30">
              {item.itemLinkRoute ? (
                <a
                  href={item.itemLinkRoute}
                  class="text-white hover:text-white/90 focus:outline-none focus:underline"
                >
                  {item.itemName}
                </a>
              ) : (
                item.itemName
              )}
            </h3>
            <nav aria-label={`${item.itemName} navigation`}>
              <ul class="space-y-3">
                {item.navigationItems.map((subItem) => (
                  <li >
                    <a
                      href={subItem.linkRoute}
                      class="text-gray-100 hover:text-white transition-colors duration-200 inline-flex items-center gap-2 text-base font-medium transform transition-transform duration-200"
                    >
                      {subItem.linkText}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        ))}
      </div>
      <div class="flex flex-col items-center justify-center space-y-4">
        <div class="flex flex-wrap justify-center gap-8 lg:gap-12 items-center">
          <div class="flex flex-col items-center group">
            <a
              href="https://www.gamblingtherapy.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center"
              aria-label={t.gamblingTherapyAria}
            >
              <GamblingTherapyLogo />
              <span class="text-gray-100 text-sm mt-2 font-medium">
                {t.gamblingTherapyLabel}
              </span>
            </a>
          </div>

          <div class="flex flex-col items-center group">
            <a
              href="https://www.begambleaware.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center"
              aria-label={t.begambleawareAria}
            >
              <img
                src="/assets/gamble-aware.webp"
                alt={t.begambleawareLabel}
                loading="lazy"
                decoding="async"
                class="h-12 w-auto"
              />
              <span class="text-gray-100 text-sm mt-2 font-medium">
                {t.begambleawareLabel}
              </span>
            </a>
          </div>

          <div class="flex flex-col items-center group">
            <div class="w-12 h-12 rounded-full border-3 border-white0 bg-gray-700 flex items-center justify-center shadow-lg hover:shadow-xl transition-all duration-300">
              <span class="text-white font-bold text-xl">18+</span>
            </div>
            <span class="text-white text-sm mt-2 font-medium">
              {t.adultsOnly}
            </span>
          </div>
        </div>

        <div class="flex flex-col items-center max-w-md text-center">
          <span class="text-white font-semibold text-base leading-relaxed mb-2">
            {t.responsibleGamble}
          </span>
          <a
            href="https://www.gamblingtherapy.org/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-base hover:text-white transition-colors font-medium"
          >
            {t.visitGamblingTherapy}
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-700 pt-6 mt-6">
      <div class="flex flex-col md:flex-row justify-between items-center text-base text-gray-100">
        <p>
          &copy; {new Date().getFullYear()} {t.copyrightRest}
        </p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a
            href={localizedStaticPageHref(locale, "terms-and-conditions")}
            class="hover:text-white transition-colors"
          >
            {t.terms}
          </a>
          <a
            href={localizedStaticPageHref(locale, "privacy-policy")}
            class="hover:text-white transition-colors"
          >
            {t.privacy}
          </a>
          <a
            href={localizedStaticPageHref(locale, "contact-us")}
            class="hover:text-white transition-colors"
          >
            {t.contact}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
