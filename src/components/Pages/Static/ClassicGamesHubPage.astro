---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../Layout/Header.astro";
import Footer from "../../Layout/Footer.astro";
import {
  homeHrefForLocale,
  localizedStaticPageHref,
  type WebsiteLocaleKey,
} from "../../../lib/sanity";
import {
  generateWebPageSchema,
  generateBreadcrumbSchema,
  generateStaticPageBreadcrumbs,
} from "../../../lib/schema";
import { LOCALES, staticSitePagesCopyFor } from "../../../lib/i18n";
import { localeIdForWebsiteLocale } from "../../../lib/i18n/websiteLocaleBridge";

interface Props {
  locale: WebsiteLocaleKey;
}

const { locale } = Astro.props as Props;
const id = localeIdForWebsiteLocale(locale);
const site = staticSitePagesCopyFor(locale);
const copy = site.classicGamesHub;
const labels = site.sitemap.labels;
const htmlLang = LOCALES[id].htmlLang;

const canonical = localizedStaticPageHref(locale, "classic-games");
const homeHref = homeHrefForLocale(locale);
const slugForSchema = canonical.replace(/^\/|\/$/g, "") || "";
/** Game play pages are only built at `/classic-games/:game/` (shared). */
const gamesBase = "/classic-games/";

const seoData = {
  title: copy.metaTitle,
  description: copy.metaDescription,
  canonical,
  openGraph: {
    title: copy.ogTitle,
    description: copy.ogDescription,
    type: "website",
  },
  keywords: copy.keywords,
};

const pageData = {
  name: copy.schemaName,
  title: copy.h1,
  slug: slugForSchema,
  description: copy.schemaDescription,
  sys: {
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  },
};

const webPageSchema = generateWebPageSchema(pageData);
const breadcrumbSchema = generateBreadcrumbSchema(
  generateStaticPageBreadcrumbs(copy.h1, {
    homeName: copy.breadcrumbHome,
    homeUrl: homeHref,
  }),
);

const g = copy.games;
---

<BaseLayout seo={seoData} lang={htmlLang}>
  <Header locale={locale} />

  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main class="flex-1 w-full min-w-0">
    <section
      class="min-h-[70vh] bg-gradient-to-b from-slate-100 via-white to-slate-50/90 border-b border-slate-200/60"
      aria-labelledby="hub-title"
    >
      <div class="container mx-auto max-w-4xl px-4 sm:px-6 pt-28 md:pt-36 pb-20 md:pb-24">
        <nav class="mb-6 text-sm" aria-label="Breadcrumb">
          <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-slate-500">
            <li>
              <a
                href={homeHref}
                class="text-blue-800 hover:text-blue-950 font-medium transition-colors"
                >{copy.breadcrumbHome}</a
              >
            </li>
            <li class="text-slate-300 select-none" aria-hidden="true">/</li>
            <li class="text-slate-700 font-medium" aria-current="page">
              {copy.h1}
            </li>
          </ol>
        </nav>

        <header class="mb-10 text-center sm:text-left max-w-3xl">
          <h1
            id="hub-title"
            class="!text-3xl sm:!text-4xl !leading-tight !font-bold !text-slate-900 !mb-0 !mt-0 tracking-tight"
          >
            {copy.h1}
          </h1>
          <p class="mt-4 text-base sm:text-lg text-slate-600 leading-relaxed">
            {copy.intro}
          </p>
        </header>

        <h2
          class="!text-xl sm:!text-2xl !font-bold !text-slate-900 !mb-4 !mt-0"
        >
          {copy.pickGame}
        </h2>
        <ul
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mb-14 list-none p-0 m-0"
        >
          <li>
            <a
              href={`${gamesBase}tetris/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.tetris}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.tetris.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.tetris.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.tetris.cta}</span
              >
            </a>
          </li>
          <li>
            <a
              href={`${gamesBase}tetris-50/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.tetris50}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.tetris50.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.tetris50.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.tetris50.cta}</span
              >
            </a>
          </li>
          <li>
            <a
              href={`${gamesBase}sudoku/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.sudoku}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.sudoku.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.sudoku.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.sudoku.cta}</span
              >
            </a>
          </li>
          <li>
            <a
              href={`${gamesBase}solitaire/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.solitaire}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.solitaire.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.solitaire.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.solitaire.cta}</span
              >
            </a>
          </li>
          <li>
            <a
              href={`${gamesBase}yukon/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.yukon}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.yukon.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.yukon.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.yukon.cta}</span
              >
            </a>
          </li>
          <li>
            <a
              href={`${gamesBase}russian/`}
              class="block h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:border-blue-200 hover:shadow-md hover:ring-blue-900/5"
            >
              <h3
                class="!text-lg !font-bold !text-slate-900 !m-0 !mb-1 !leading-snug"
              >
                {labels.russian}
              </h3>
              <p class="text-sm text-slate-500 mb-3 m-0">{g.russian.tagline}</p>
              <p class="text-slate-600 text-sm leading-relaxed m-0">
                {g.russian.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-blue-800"
                >{g.russian.cta}</span
              >
            </a>
          </li>
        </ul>

        <p class="text-slate-600 text-base leading-relaxed max-w-3xl m-0">
          {copy.footerComparison.beforeTetris}{" "}
          <a
            href={`${gamesBase}tetris/`}
            class="text-blue-800 font-medium underline decoration-blue-200 underline-offset-2 hover:text-blue-950"
            >{copy.footerComparison.tetrisLabel}</a
          >
          {" "}
          {copy.footerComparison.between}{" "}
          <a
            href={`${gamesBase}tetris-50/`}
            class="text-blue-800 font-medium underline decoration-blue-200 underline-offset-2 hover:text-blue-950"
            >{copy.footerComparison.tetris50Label}</a
          >
          {" "}
          {copy.footerComparison.after}
        </p>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
