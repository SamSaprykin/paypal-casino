---
import { CircleHelp } from "@lucide/astro";
import { MarkdownSnippet } from "./MarkdownSnippet.jsx";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items?: FaqItem[];
  spaceTop?: number;
}

const { title, items = [], spaceTop = 0 } = Astro.props;

const paddingTopMap: Record<number, string> = {
  0: "pt-0",
  4: "pt-4",
  6: "pt-6",
  8: "pt-8",
  12: "pt-12",
  16: "pt-16",
};

const ptClass = paddingTopMap[spaceTop] ?? "pt-8 md:pt-12";
---

{items.length > 0 && (
  <section
    class:list={[
      "px-4 sm:px-6 pb-12 md:pb-16 bg-gradient-to-b from-blue-50/60 via-white to-white",
      ptClass,
    ]}
    aria-labelledby={title ? "faq-heading" : undefined}
  >
    <div class="max-w-3xl mx-auto mt-8 md:mt-12">
      {title ? (
        <header class="text-center mb-8 md:mb-10">
          <div
            class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-white border border-blue-100 shadow-sm mb-4"
            aria-hidden="true"
          >
            <CircleHelp class="w-7 h-7 text-blue-600" />
          </div>
          <h2
            id="faq-heading"
            class="text-2xl md:text-3xl font-bold text-gray-900 text-balance tracking-tight"
          >
            {title}
          </h2>
          <div
            class="w-16 h-1 bg-gradient-to-r from-blue-500 to-blue-600 mx-auto mt-4 rounded-full"
            aria-hidden="true"
          />
        </header>
      ) : null}

      <dl class="space-y-4 md:space-y-5">
        {items.map(({ question, answer }, index) => (
          <div class="rounded-2xl border border-blue-100 bg-white shadow-sm overflow-hidden ring-1 ring-blue-50/80">
            <dt class="flex gap-3.5 md:gap-4 px-4 py-4 md:px-6 md:py-5 bg-gradient-to-r from-blue-50/90 to-white">
              <span
                class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-bold flex items-center justify-center shadow-sm"
                aria-hidden="true"
              >
                {index + 1}
              </span>
              <span class="text-base md:text-lg font-semibold text-blue-950 leading-snug pt-0.5">
                {question}
              </span>
            </dt>
            <dd class="px-4 py-4 md:px-6 md:py-5 md:pl-[3.75rem] border-t border-blue-50/80">
              <div class="text-[15px] md:text-base text-gray-700 leading-relaxed [&_.prose]:prose-sm [&_.prose]:md:prose-base [&_.prose_p]:text-gray-700 [&_.prose_p]:leading-relaxed [&_.prose_a]:text-blue-700 [&_.prose_a]:font-medium">
                <MarkdownSnippet markdown={answer} />
              </div>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
)}
