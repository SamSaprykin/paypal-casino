---
import { Star } from "@lucide/astro";

interface Props {
  rating?: number | string | null;
  class?: string;
  /** Pixel-consistent star size */
  size?: "sm" | "md" | "lg";
  /** Overrides built-in "X out of 5 stars" / "Not rated" for accessibility */
  ariaLabel?: string;
}

const { rating, class: className = "", size = "md", ariaLabel: ariaLabelProp } = Astro.props;

const r =
  rating == null || rating === ""
    ? null
    : Math.min(5, Math.max(0, Number(rating)));

const starFills = Array.from({ length: 5 }, (_, i) =>
  r == null ? 0 : Math.min(Math.max(r - i, 0), 1),
);

const sizeCls =
  size === "lg" ? "h-5 w-5" : size === "sm" ? "h-3.5 w-3.5" : "h-4 w-4";

const defaultAria = r == null ? "Not rated" : `${r} out of 5 stars`;
const ariaLabel = ariaLabelProp ?? defaultAria;
---

<div
  class:list={["flex items-center gap-0.5", className]}
  role="img"
  aria-label={ariaLabel}
>
  {
    starFills.map((fill) => (
      <span class:list={["relative inline-block shrink-0", sizeCls]}>
        <Star
          class:list={["absolute inset-0 fill-neutral-200 text-neutral-500", sizeCls]}
        />
        <span
          class="absolute left-0 top-0 h-full overflow-hidden transition-[width] duration-150"
          style={`width: ${fill * 100}%`}
        >
          <Star
            class:list={[
              "fill-amber-500 text-amber-900 drop-shadow-[0_1px_1px_rgba(0,0,0,0.18)]",
              sizeCls,
            ]}
          />
        </span>
      </span>
    ))
  }
</div>
