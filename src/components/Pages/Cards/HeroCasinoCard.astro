---
import { ArrowRight } from "@lucide/astro";
import CustomButton from "../../../components/Atoms/Button.astro";
import RatingStars from "./RatingStars.astro";
import { addHttps } from "../../../lib/helpers";
import { Image } from "astro:assets";
import {
  CASINO_LISTING_CARD_COPY,
  CASINO_HERO_CARD_COPY,
  formatRatingOutOfFive,
  getRatingGradationLabel,
  type CasinoListingCardCopy,
  type LocaleId,
} from "../../../lib/i18n";

interface Props {
  casino: any;
  /** Used for star gradation labels (defaults by locale). */
  listingCopy?: CasinoListingCardCopy;
  locale?: LocaleId;
}

const { casino, listingCopy: listingCopyProp, locale = "en-IE" } = Astro.props;

const listingCopy = listingCopyProp ?? CASINO_LISTING_CARD_COPY[locale];
const heroButtonCopy = CASINO_HERO_CARD_COPY[locale];
const reviewHref = casino?.fields?.reviewHref;

const ratingValue = casino?.fields?.casinoRates?.[0]?.fields?.ratingNumber;
const ratingOutOfFive = formatRatingOutOfFive(ratingValue);
const gradationLabel = getRatingGradationLabel(ratingValue, listingCopy);
const starsAriaLabel =
  ratingValue != null && Number.isFinite(Number(ratingValue))
    ? `${gradationLabel}. ${Number(ratingValue)} out of 5 stars.`
    : listingCopy.ratingNotRated;
---

<div class="relative flex flex-col items-center rounded-lg border border-gray-200 bg-white shadow-md transition-all duration-300 transform hover:-translate-y-1">
  <!-- Header with minimal background -->
  <div class="relative flex w-full flex-col items-center bg-gray-100 p-4 text-gray-900">
    <div
      class="-mt-8 mb-2 rounded-lg bg-white p-1 shadow-sm"
      style={`background-color:${casino?.fields?.backgroundColor}`}
    >
      <Image
        src={addHttps(casino?.fields?.logo?.fields?.file?.url) || "/placeholder.svg"}
        alt={`${casino?.fields?.casinoName} logo`}
        width="50"
        height="50"
        class="h-32 w-32 rounded-md object-contain"
        loading="lazy"
      />
    </div>
    <h2 class="mb-2 text-center text-2xl font-semibold text-gray-900">
      {reviewHref ? (
        <a
          href={reviewHref}
          class="underline decoration-blue-300 underline-offset-2 transition-colors duration-200 hover:text-blue-700 hover:decoration-blue-600"
          aria-label={`${heroButtonCopy.readReview}: ${casino?.fields?.casinoName}`}
        >
          {casino?.fields?.casinoName}
        </a>
      ) : (
        casino?.fields?.casinoName
      )}
    </h2>
    <div class="mb-1 flex flex-col items-center gap-1 rounded-full bg-gray-200/90 px-4 py-2">
      <span class="text-center text-base font-bold tabular-nums tracking-tight text-gray-900">
        {ratingOutOfFive}
      </span>
      <RatingStars rating={ratingValue} size="lg" ariaLabel={starsAriaLabel} />
      <span class="text-center text-xs font-semibold text-gray-800">{gradationLabel}</span>
    </div>
  </div>

  <!-- Card Content -->
  <div class="w-full p-4 text-center">
    <p class="mb-3 line-clamp-2 text-sm text-gray-700">
      {casino?.fields?.shortDescription}
    </p>

    <!-- Bonus Section -->
    <div class="mb-4 rounded-lg border border-gray-200 bg-gray-50 p-3">
      <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-600">
        {casino?.fields?.bonuses?.[0]?.fields?.code}
      </p>
      <p class="text-base font-bold text-gray-800">
        {casino?.fields?.bonuses?.[0]?.fields?.description}
      </p>
    </div>

    <!-- Action Buttons -->
    <div class="flex w-full flex-col gap-2">
      <CustomButton
        variant="primary"
        size="lg"
        className="w-full group"
        buttonType="external-ref-link"
        refLink={casino?.fields?.referralUrl}
      >
        <span class="cta-text text-md">{heroButtonCopy.playNow}</span>
        <ArrowRight class="ml-2 h-4 w-4 transform rounded-full transition-all duration-300 group-hover:ml-4 group-hover:bg-blue-100 group-hover:text-gray-600" />
      </CustomButton>
    </div>
  </div>
</div>
