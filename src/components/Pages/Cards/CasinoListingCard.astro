---
import { ArrowRight, ChevronDown, Globe, Clock, Users, CreditCard } from "@lucide/astro";
import CustomButton from "../../../components/Atoms/Button.astro";
import RatingStars from "./RatingStars.astro";
import { addHttps } from "../../../lib/helpers";
import { Image } from "astro:assets";
import {
  CASINO_LISTING_CARD_COPY,
  formatRatingOutOfFive,
  getRatingGradationLabel,
  type CasinoListingCardCopy,
} from "../../../lib/i18n";

interface Props {
  casino: any;
  copy?: CasinoListingCardCopy;
}

const { casino, copy: copyProp } = Astro.props as Props;
const copy = copyProp ?? CASINO_LISTING_CARD_COPY["en-IE"];
const reviewHref = casino?.fields?.reviewHref;

const firstBonus = casino.fields?.bonuses ? casino.fields?.bonuses[0] : null;
const ratingValue = casino?.fields?.casinoRates?.[0]?.fields?.ratingNumber;

const recommendationPercentage = Math.round(
  (casino?.fields?.userRecommendationsRecommendedNumber /
    casino?.fields?.userRecommendationsTotalNumber) *
    100
);

const recNum = casino?.fields?.userRecommendationsRecommendedNumber || 0;
const totNum = casino?.fields?.userRecommendationsTotalNumber || 0;
const userRecommendText = copy.userRecommendTemplate
  .replace("{{rec}}", String(recNum))
  .replace("{{tot}}", String(totNum));
const positiveReviewsText = copy.positiveReviewsTemplate.replace(
  "{{pct}}",
  String(recommendationPercentage || 0)
);

const gradationLabel = getRatingGradationLabel(ratingValue, copy);
const ratingOutOfFive = formatRatingOutOfFive(ratingValue);
const starsAriaLabel =
  ratingValue != null && Number.isFinite(Number(ratingValue))
    ? `${gradationLabel}. ${Number(ratingValue)} out of 5 stars.`
    : copy.ratingNotRated;

---

<div
  class="casino-card bg-white transition-[max-height] duration-500 rounded-lg shadow-md border border-gray-200 md:overflow-hidden hover:shadow-lg"
>
  <!-- Main horizontal layout -->
  <div class="main-row flex items-center justify-between h-[158px] lg:h-[124px]">
    <!-- 1. Logo + Casino Name Column -->
    <div class="flex flex-col p-1.5 lg:p-0 w-1/2 lg:w-auto">
      <div
        class="flex flex-col items-center justify-center p-2.5 border border-gray-200 rounded-md mx-3 my-1 min-w-[100px] lg:min-w-[136px] -mt-7 md:mt-0"
        style={`background-color:${casino?.fields?.backgroundColor}`}
      >
        <div class="mb-1 flex h-[34px] w-[72px] items-center justify-center overflow-hidden">
          <Image
            src={addHttps(casino?.fields?.logo?.fields?.file?.url)}
            alt={`${casino?.fields?.casinoName} logo`}
            width={72}
            height={34}
            format="webp"
            class="rounded-md object-contain w-full h-full"
            loading="lazy"
            style="object-fit: contain; width: 100%; height: 100%;"
          />
        </div>

        {reviewHref ? (
          <a
            href={reviewHref}
            class="text-sm text-center font-semibold text-gray-100 leading-tight underline decoration-gray-200/80 underline-offset-2 transition-colors duration-200 hover:decoration-white hover:text-white"
            aria-label={`${copy.readReview}: ${casino?.fields?.casinoName}`}
          >
            {casino?.fields?.casinoName}
          </a>
        ) : (
          <span class="text-sm text-center font-semibold text-gray-100 leading-tight">
            {casino?.fields?.casinoName}
          </span>
        )}
      </div>
      <div class="mb-0.5 mx-auto flex max-w-[90%] flex-col items-center gap-0.5 rounded-xl md:rounded-full bg-blue-50 px-2 py-1.5 lg:hidden">
        <span class="text-center text-xs font-bold tabular-nums tracking-tight text-blue-950">
          {ratingOutOfFive}
        </span>
        <RatingStars rating={ratingValue} ariaLabel={starsAriaLabel} size="sm" />
        <span class="text-center text-[11px] font-semibold leading-tight text-blue-900">{gradationLabel}</span>
      </div>
    </div>

    <!-- 2. Rating Column -->
    <div class="hidden min-w-[92px] flex-col items-center justify-center lg:flex lg:px-2">
      <div class="mb-0.5 flex flex-col items-center gap-0.5 rounded-md md:rounded-full bg-blue-50 px-2 py-1.5">
        <span class="text-center text-xs font-bold tabular-nums tracking-tight text-blue-950">
          {ratingOutOfFive}
        </span>
        <RatingStars rating={ratingValue} ariaLabel={starsAriaLabel} size="sm" />
        <span class="text-center text-[11px] font-semibold leading-tight text-blue-900">{gradationLabel}</span>
      </div>
    </div>

    <!-- 3. Bonus Info + Description Column -->
    <div class="flex-1 px-3 hidden lg:block min-w-[200px]">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg p-2 border border-blue-200">
        <p class="text-[11px] text-blue-700 font-bold mb-0.5 uppercase tracking-wide">
          {firstBonus?.fields?.code || copy.welcomeBonusFallback}
        </p>
        <p class="text-blue-950 font-bold text-xs leading-snug">
          {firstBonus?.fields?.description || copy.defaultBonusDescription}
        </p>
      </div>
    </div>

    <!-- 4. Casino Short Description Column -->
    <div class="px-3 max-w-[340px] hidden lg:block">
      <p class="text-xs text-blue-900 leading-snug">
        {casino?.fields?.shortDescription || copy.defaultShortDescription}
      </p>
    </div>

    <!-- 5. Buttons Column -->
    <div class="flex flex-col justify-center gap-1.5 border-l border-gray-200 min-w-1/2 lg:min-w-[200px] h-full min-h-[124px] md:min-h-full">
      <div class="flex flex-col gap-1.5 p-0 px-3 md:p-3">
        <CustomButton
          variant="primary"
          className="cta-btn w-full group min-h-[36px] font-semibold text-sm md:text-sm py-2"
          buttonType="external-ref-link"
          refLink={casino?.fields?.referralUrl}
        >
          <span class="cta-text text-sm">{copy.playNow}</span>
          <ArrowRight class="w-3.5 h-3.5 ml-0.5 transform transition-all duration-300 group-hover:translate-x-1 group-hover:text-gray-600 rounded-full group-hover:bg-blue-100" />
        </CustomButton>

        <div class="pt-1">
          <button
            class="toggle-btn min-h-[36px] w-full flex items-center justify-center gap-1 px-2.5 py-1.5 text-blue-700 hover:text-blue-900 bg-blue-100 hover:bg-blue-200 rounded-md transition-colors duration-200 font-semibold text-sm hover:cursor-pointer"
          >
            {copy.showMore}
            <ChevronDown class="chevron w-3.5 h-3.5" />
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Expandable Additional Information -->
  <div class="extra border-t border-gray-200 bg-blue-50 p-3 opacity-0 max-h-0 overflow-hidden transition-all duration-500">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
      {/* License block inserted here */}
      <div class="space-y-1.5">
        <div class="flex items-center gap-1.5">
          <Globe class="w-3.5 h-3.5 text-blue-600" />
          <div class="text-xs font-semibold text-blue-900">License</div>
        </div>
        <div>
          <span class="text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">Curacao: AT0uc033</span>
        </div>
      </div>

      <div class="flex-1 block lg:hidden">
        <div class="bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg p-2 border border-blue-200">
          <p class="text-[11px] text-blue-700 font-bold mb-0.5 uppercase tracking-wide">
            {firstBonus?.fields?.code || copy.welcomeBonusFallback}
          </p>
          <p class="text-blue-900 font-bold text-xs leading-snug">
            {firstBonus?.fields?.description || copy.defaultBonusDescription}
          </p>
        </div>
      </div>

      <div class="space-y-1.5 flex flex-col items-start lg:px-4">
        <div class="flex items-center gap-1.5">
          <CreditCard class="w-3.5 h-3.5 text-blue-900" />
          <div class="text-xs font-semibold text-blue-900">{copy.payoutLimits}</div>
        </div>
        <p class="text-[11px] leading-snug text-blue-700">{casino?.fields?.payoutLimits}</p>
      </div>

      {casino?.fields?.payoutTimes && (
        <div class="space-y-1.5 flex flex-col items-start px-0">
          <div class="flex items-center gap-1.5">
            <Clock class="w-3.5 h-3.5 text-blue-900" />
            <div class="text-xs font-semibold text-blue-900">{copy.payoutTimes}</div>
          </div>
          <div class="space-y-0.5">
            {casino?.fields?.payoutTimes.map((time) => (
              <p class="text-[11px] leading-snug text-blue-700">{time}</p>
            ))}
          </div>
        </div>
      )}

      <div class="w-full max-w-[340px] block lg:hidden font-semibold">
        <h3 class="text-xs text-blue-900 leading-snug">
          {casino?.fields?.shortDescription || copy.defaultShortDescription}
        </h3>
      </div>

      <div class="space-y-1.5 flex flex-col border border-blue-50 bg-blue-50 rounded-lg py-3 lg:p-0 lg:border-none lg:bg-transparent">
        <div class="flex items-center gap-1.5">
          <Users class="w-3.5 h-3.5 text-blue-900" />
          <div class="text-xs font-semibold text-blue-900">{copy.userReviews}</div>
        </div>
        <div class="space-y-0.5">
          <p class="text-[11px] leading-snug text-blue-700">
            {userRecommendText}
          </p>
          <div class="w-full bg-blue-200 rounded-full h-1.5">
            <div
              class="bg-blue-500 h-1.5 rounded-full transition-all duration-300 max-w-[100%]"
              style={`width:${recommendationPercentage || 0}%`}
            ></div>
          </div>
          <p class="text-[11px] text-blue-600 font-semibold">
            {positiveReviewsText}
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Select all casino cards
    const cards = document.querySelectorAll(".casino-card");

    cards.forEach((card) => {
      const btn = card.querySelector(".toggle-btn");
      const chevron = card.querySelector(".chevron");
      const extra = card.querySelector(".extra");
      const mainRow = card.querySelector(".main-row");

      if (!btn || !extra || !mainRow) return;

      // Set initial collapsed height
      const baseHeight = (mainRow as HTMLElement).offsetHeight;
      (card as HTMLElement).style.maxHeight = baseHeight + "px";

      btn.addEventListener("click", () => {
        const isOpen = extra.classList.contains("open");

        if (isOpen) {
          extra.classList.remove("open");
          (extra as HTMLElement).style.maxHeight = "0";
          (extra as HTMLElement).style.opacity = "0";
          (card as HTMLElement).style.maxHeight = baseHeight + "px";
          chevron && chevron.classList.remove("rotate-180");
        } else {
          extra.classList.add("open");
          (extra as HTMLElement).style.maxHeight = extra.scrollHeight + "px";
          (extra as HTMLElement).style.opacity = "1";
          (card as HTMLElement).style.maxHeight = baseHeight + extra.scrollHeight + "px";
          chevron && chevron.classList.add("rotate-180");
        }
      });
    });

  });
</script>
