---
import { ArrowRight, ChevronDown, Globe, Clock, Users, CreditCard } from "@lucide/astro";
import CustomButton from "../../../components/Atoms/Button.astro";
import RatingStars from "./RatingStars.astro";
import { addHttps } from "../../../lib/helpers";
import { Image } from "astro:assets";
import {
  CASINO_LISTING_CARD_COPY,
  formatRatingOutOfFive,
  getRatingGradationLabel,
  type CasinoListingCardCopy,
} from "../../../lib/i18n";

interface Props {
  casino: any;
  copy?: CasinoListingCardCopy;
}

const { casino, copy: copyProp } = Astro.props as Props;
const copy = copyProp ?? CASINO_LISTING_CARD_COPY["en-IE"];

const firstBonus = casino.fields?.bonuses ? casino.fields?.bonuses[0] : null;
const ratingValue = casino?.fields?.casinoRates?.[0]?.fields?.ratingNumber;

const recommendationPercentage = Math.round(
  (casino?.fields?.userRecommendationsRecommendedNumber /
    casino?.fields?.userRecommendationsTotalNumber) *
    100
);

const recNum = casino?.fields?.userRecommendationsRecommendedNumber || 0;
const totNum = casino?.fields?.userRecommendationsTotalNumber || 0;
const userRecommendText = copy.userRecommendTemplate
  .replace("{{rec}}", String(recNum))
  .replace("{{tot}}", String(totNum));
const positiveReviewsText = copy.positiveReviewsTemplate.replace(
  "{{pct}}",
  String(recommendationPercentage || 0)
);

const gradationLabel = getRatingGradationLabel(ratingValue, copy);
const ratingOutOfFive = formatRatingOutOfFive(ratingValue);
const starsAriaLabel =
  ratingValue != null && Number.isFinite(Number(ratingValue))
    ? `${gradationLabel}. ${Number(ratingValue)} out of 5 stars.`
    : copy.ratingNotRated;

---

<div
  class="casino-card bg-white transition-[max-height] duration-500 rounded-lg shadow-md border border-gray-200 md:overflow-hidden hover:shadow-lg"
>
  <!-- Main horizontal layout -->
  <div class="main-row flex items-center justify-between h-[180px] lg:h-[140px]">
    <!-- 1. Logo + Casino Name Column -->
    <div class="flex flex-col p-2 lg:p-0 w-1/2 lg:w-auto">
      <div
        class="flex flex-col items-center justify-center p-4 border border-gray-200 rounded-md mx-4 my-2 min-w-[110px] lg:min-w-[160px] -mt-8 md:mt-0"
        style={`background-color:${casino?.fields?.backgroundColor}`}
      >
        <div class="mb-2 flex h-[40px] w-[80px] items-center justify-center">
          <Image
            src={addHttps(casino?.fields?.logo?.fields?.file?.url) || "/placeholder.svg"}
            alt={`${casino?.fields?.casinoName} logo`}
            width="90"
            height="50"
            format="webp"
            class="rounded-md object-contain"
            loading="lazy"
          />
        </div>
        <span class="text-md text-center font-semibold text-gray-100">
          {casino?.fields?.casinoName}
        </span>
      </div>
      <div class="mb-1 mx-auto flex max-w-[90%] flex-col items-center gap-1 rounded-xl md:rounded-full bg-blue-50 px-3 py-2 lg:hidden">
        <span class="text-center text-sm font-bold tabular-nums tracking-tight text-blue-950">
          {ratingOutOfFive}
        </span>
        <RatingStars rating={ratingValue} ariaLabel={starsAriaLabel} />
        <span class="text-center text-xs font-semibold text-blue-900">{gradationLabel}</span>
      </div>
    </div>

    <!-- 2. Rating Column -->
    <div class="hidden min-w-[100px] flex-col items-center justify-center lg:flex lg:px-4">
      <div class="mb-1 flex flex-col items-center gap-1 rounded-md md:rounded-full bg-blue-50 px-3 py-2">
        <span class="text-center text-sm font-bold tabular-nums tracking-tight text-blue-950">
          {ratingOutOfFive}
        </span>
        <RatingStars rating={ratingValue} ariaLabel={starsAriaLabel} />
        <span class="text-center text-xs font-semibold text-blue-900">{gradationLabel}</span>
      </div>
    </div>

    <!-- 3. Bonus Info + Description Column -->
    <div class="flex-1 px-4 hidden lg:block">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg p-3 border border-blue-200">
        <p class="text-xs text-blue-700 font-bold mb-1 uppercase tracking-wide">
          {firstBonus?.fields?.code || copy.welcomeBonusFallback}
        </p>
        <p class="text-blue-950 font-bold text-sm">
          {firstBonus?.fields?.description || copy.defaultBonusDescription}
        </p>
      </div>
    </div>

    <!-- 4. Casino Short Description Column -->
    <div class="px-4 max-w-[360px] hidden lg:block">
      <p class="text-sm text-blue-900 leading-relaxed">
        {casino?.fields?.shortDescription || copy.defaultShortDescription}
      </p>
    </div>

    <!-- 5. Buttons Column -->
    <div class="flex flex-col justify-center gap-2 border-l border-gray-200 min-w-1/2 lg:min-w-[220px] h-full min-h-[140px] md:min-h-full">
      <div class="flex flex-col gap-2 p-0 px-4 md:p-4">
        <CustomButton
          variant="primary"
          className="cta-btn w-full group min-h-[40px] font-semibold text-md"
          buttonType="external-ref-link"
          refLink={casino?.fields?.referralUrl}
        >
          <span class="cta-text text-md">{copy.playNow}</span>
          <ArrowRight class="w-4 h-4 ml-1 transform transition-all duration-300 group-hover:translate-x-1 group-hover:text-gray-600 rounded-full group-hover:bg-blue-100" />
        </CustomButton>

        <div class="pt-2">
          <button
            class="toggle-btn min-h-[40px] w-full flex items-center justify-center gap-1 px-3 py-2 text-blue-700 hover:text-blue-900 bg-blue-100 hover:bg-blue-200 rounded-md transition-colors duration-200 font-semibold text-md hover:cursor-pointer"
          >
            {copy.showMore}
            <ChevronDown class="chevron w-4 h-4" />
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Expandable Additional Information -->
  <div class="extra border-t border-gray-200 bg-blue-50 p-4 opacity-0 max-h-0 overflow-hidden transition-all duration-500">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {/* License block inserted here */}
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <Globe class="w-4 h-4 text-blue-600" />
          <div class="text-sm font-semibold text-blue-900">License</div>
        </div>
        <div>
          <span class="text-sm bg-blue-100 text-blue-800 px-2 py-1 rounded-full">Curacao: AT0uc033</span>
        </div>
      </div>

      <div class="flex-1 block lg:hidden">
        <div class="bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg p-3 border border-blue-200">
          <p class="text-xs text-blue-700 font-bold mb-1 uppercase tracking-wide">
            {firstBonus?.fields?.code || copy.welcomeBonusFallback}
          </p>
          <p class="text-blue-900 font-bold text-sm">
            {firstBonus?.fields?.description || copy.defaultBonusDescription}
          </p>
        </div>
      </div>

      <div class="space-y-2 flex flex-col items-start lg:px-6">
        <div class="flex items-center gap-2">
          <CreditCard class="w-4 h-4 text-blue-900" />
          <div class="text-sm font-semibold text-blue-900">{copy.payoutLimits}</div>
        </div>
        <p class="text-xs text-blue-700">{casino?.fields?.payoutLimits}</p>
      </div>

      {casino?.fields?.payoutTimes && (
        <div class="space-y-2 flex flex-col items-start px-0">
          <div class="flex items-center gap-2">
            <Clock class="w-4 h-4 text-blue-900" />
            <div class="text-sm font-semibold text-blue-900">{copy.payoutTimes}</div>
          </div>
          <div class="space-y-1">
            {casino?.fields?.payoutTimes.map((time) => (
              <p class="text-xs text-blue-700">{time}</p>
            ))}
          </div>
        </div>
      )}

      <div class="w-full max-w-[360px] block lg:hidden font-semibold">
        <h3 class="text-sm text-blue-900 leading-relaxed">
          {casino?.fields?.shortDescription || copy.defaultShortDescription}
        </h3>
      </div>

      <div class="space-y-2 flex flex-col border border-blue-50 bg-blue-50 rounded-lg py-4 lg:p-0 lg:border-none lg:bg-transparent">
        <div class="flex items-center gap-2">
          <Users class="w-4 h-4 text-blue-900" />
          <div class="text-sm font-semibold text-blue-900">{copy.userReviews}</div>
        </div>
        <div class="space-y-1">
          <p class="text-xs text-blue-700">
            {userRecommendText}
          </p>
          <div class="w-full bg-blue-200 rounded-full h-2">
            <div
              class="bg-blue-500 h-2 rounded-full transition-all duration-300 max-w-[100%]"
              style={`width:${recommendationPercentage || 0}%`}
            ></div>
          </div>
          <p class="text-xs text-blue-600 font-semibold">
            {positiveReviewsText}
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Select all casino cards
    const cards = document.querySelectorAll(".casino-card");

    cards.forEach((card) => {
      const btn = card.querySelector(".toggle-btn");
      const chevron = card.querySelector(".chevron");
      const extra = card.querySelector(".extra");
      const mainRow = card.querySelector(".main-row");

      if (!btn || !extra || !mainRow) return;

      // Set initial collapsed height
      const baseHeight = (mainRow as HTMLElement).offsetHeight;
      (card as HTMLElement).style.maxHeight = baseHeight + "px";

      btn.addEventListener("click", () => {
        const isOpen = extra.classList.contains("open");

        if (isOpen) {
          extra.classList.remove("open");
          (extra as HTMLElement).style.maxHeight = "0";
          (extra as HTMLElement).style.opacity = "0";
          (card as HTMLElement).style.maxHeight = baseHeight + "px";
          chevron && chevron.classList.remove("rotate-180");
        } else {
          extra.classList.add("open");
          (extra as HTMLElement).style.maxHeight = extra.scrollHeight + "px";
          (extra as HTMLElement).style.opacity = "1";
          (card as HTMLElement).style.maxHeight = baseHeight + extra.scrollHeight + "px";
          chevron && chevron.classList.add("rotate-180");
        }
      });
    });

  });
</script>
