---
import CustomImage from "../../CustomImage.astro";
import type { ImageSection, WebsiteLocaleKey } from "../../../lib/content";
import { ROOT_WEBSITE_LOCALE } from "../../../lib/content";

interface Props {
  section: ImageSection;
  locale?: WebsiteLocaleKey;
}

const { section, locale = ROOT_WEBSITE_LOCALE } = Astro.props;
const hasSrc = Boolean(section.src && section.src.trim());
---

{
  hasSrc ? (
    <section class="px-6 sm:px-8">
      <CustomImage
        src={section.src!}
        alt={section.alt ?? ""}
        caption={section.caption}
        width={section.width}
        height={section.height}
        locale={locale}
      />
    </section>
  ) : null
}
