---
import CasinoListingCard from "../Cards/CasinoListingCard.astro";
import { MarkdownSnippet } from "../MarkdownSnippet.jsx";
import type { CasinoListSection, WebsiteLocaleKey } from "../../../lib/content";
import { ROOT_WEBSITE_LOCALE } from "../../../lib/content";
import { CASINO_LISTING_CARD_COPY, localeIdForWebsiteLocale } from "../../../lib/i18n";

interface Props {
  section: CasinoListSection;
  locale?: WebsiteLocaleKey;
}

const { section, locale = ROOT_WEBSITE_LOCALE } = Astro.props;
const { anchorTitle, copyBefore, copyAfter, casinos } = section;
const cardCopy = CASINO_LISTING_CARD_COPY[localeIdForWebsiteLocale(locale)];
---

<div class="bg-blue-50/50 py-3 lg:py-3 px-3 sm:px-4">
  <div class="max-w-6xl mx-auto py-3 lg:py-4">
    {copyBefore ? (
      <h2
        class="text-xl md:text-2xl font-bold pt-4 lg:pt-8 text-center text-gray-800"
        id={anchorTitle ?? undefined}
      >
        {copyBefore}
      </h2>
    ) : null}

    {casinos.length > 0 && (
      <div class="grid flex flex-col gap-3 md:gap-3 container mx-auto mt-6 md:mt-8 mb-3">
        {casinos.map((casino) => (
          <CasinoListingCard casino={casino} copy={cardCopy} />
        ))}
      </div>
    )}

    {copyAfter && copyAfter.trim() ? (
      <div class="max-w-3xl mx-auto mt-8 px-2">
        <MarkdownSnippet markdown={copyAfter} />
      </div>
    ) : null}
  </div>
</div>
