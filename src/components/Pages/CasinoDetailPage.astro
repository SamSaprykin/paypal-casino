---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Layout/Header.astro";
import Footer from "../../components/Layout/Footer.astro";
import CasinoReviewHero from "../../components/Pages/CasinoReviewHero.astro";
import { ContentComponent } from "../../components/Pages/ContentComponent.jsx";
import { FaqAccordion } from "../../components/Pages/FAQComponent.jsx";

import {
 CASINO_DETAIL_PAGE_COPY,
 localeIdForWebsiteLocale,
 LOCALES,
} from "../../lib/i18n";
import {
 homeHrefForLocale,
 localizedCasinoDetailHref,
 type WebsiteLocaleKey,
} from "../../lib/sanity";
import type { CasinoPage } from "../../lib/sanity/casinos";
import { format } from "date-fns";

interface Props {
 casino: CasinoPage;
 locale: WebsiteLocaleKey;
}

const { casino, locale } = Astro.props as Props;

const localeId = localeIdForWebsiteLocale(locale);
const copy = CASINO_DETAIL_PAGE_COPY[localeId];
const htmlLang = LOCALES[localeId].htmlLang;
const homeHref = homeHrefForLocale(locale);

const canonicalPath = localizedCasinoDetailHref(locale, casino.slug);

const seoData = {
 title:
 casino.seo?.seoTitle ||
 `${casino.casinoName} Review - PayPal Casino Reviews`,
 description:
 casino.seo?.seoDescription ||
 casino.shortDescription ||
 `Read our ${casino.casinoName} review — bonuses, payments, pros and cons.`,
 canonical: canonicalPath,
 openGraph: {
 title: casino.seo?.seoTitle || `${casino.casinoName} Review`,
 description: casino.seo?.seoDescription || casino.shortDescription,
 type: "website",
 image: casino.logoUrl,
 },
};

const firstBonus = casino.bonuses[0] ?? null;

function formatReviewDate(iso: string) {
 try {
 return format(new Date(iso), "MMMM d, yyyy");
 } catch {
 return iso;
 }
}

const tagListClass =
 "flex flex-wrap gap-2 list-none p-0 m-0 [&>li]:rounded-full [&>li]:bg-slate-100 [&>li]:px-3 [&>li]:py-1 [&>li]:text-sm [&>li]:text-slate-700";
---

<BaseLayout seo={seoData} lang={htmlLang}>
 <Header locale={locale} localeHrefs={casino.countrySelectorHrefs} />
 <main class="min-h-screen pb-16">
 <div
 class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-900 to-primary-950 pt-24 lg:pt-32"
 >
 <div
 class="pointer-events-none absolute -left-16 top-8 h-48 w-48 rounded-full bg-primary-400/10 blur-3xl"
 aria-hidden="true"
 >
 </div>
 <div
 class="pointer-events-none absolute -right-12 bottom-0 h-56 w-56 rounded-full bg-primary-300/10 blur-3xl"
 aria-hidden="true"
 >
 </div>
 <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
 <CasinoReviewHero
 casino={casino}
 localeId={localeId}
 homeHref={homeHref}
 pageTitle={casino.seo?.seoTitle}
 />
 </div>
 </div>

 <div class="mx-auto max-w-5xl bg-gradient-to-b from-primary-50/40 to-white px-4 pb-4 pt-10 sm:px-6 lg:px-8">

 {
 casino.bodyMarkdown?.trim() ? (
 <section class="mb-12 rounded-2xl border border-slate-200/80 bg-white/80 p-6 shadow-sm sm:p-8">
 <ContentComponent
 client:only="react"
 content={casino.bodyMarkdown}
 firstBonus={firstBonus}
 />
 </section>
 ) : null
 }

{
 casino.payoutLimits ||
 casino.payoutTimes?.length ||
 casino.software?.length ||
 casino.depositMethods?.length ||
 casino.withdrawalMethods?.length ||
 casino.license ? (
 <section class="mb-12 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
 <dl class="grid gap-6 sm:grid-cols-2">
 {casino.payoutLimits ? (
 <div>
 <dt class="mb-1 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.payoutLimits}
 </dt>
 <dd class="text-gray-800">{casino.payoutLimits}</dd>
 </div>
 ) : null}
 {casino.license ? (
 <div>
 <dt class="mb-1 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.license}
 </dt>
 <dd class="text-gray-800">{casino.license}</dd>
 </div>
 ) : null}
 {casino.payoutTimes?.length ? (
 <div class="sm:col-span-2">
 <dt class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.payoutTimes}
 </dt>
 <dd>
 <ul class={tagListClass}>
 {casino.payoutTimes.map((time) => (
 <li>{time}</li>
 ))}
 </ul>
 </dd>
 </div>
 ) : null}
 {casino.software?.length ? (
 <div class="sm:col-span-2">
 <dt class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.software}
 </dt>
 <dd>
 <ul class={tagListClass}>
 {casino.software.map((item) => (
 <li>{item}</li>
 ))}
 </ul>
 </dd>
 </div>
 ) : null}
 {casino.depositMethods?.length ? (
 <div class="sm:col-span-2">
 <dt class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.depositMethods}
 </dt>
 <dd>
 <ul class={tagListClass}>
 {casino.depositMethods.map((item) => (
 <li>{item}</li>
 ))}
 </ul>
 </dd>
 </div>
 ) : null}
 {casino.withdrawalMethods?.length ? (
 <div class="sm:col-span-2">
 <dt class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
 {copy.withdrawalMethods}
 </dt>
 <dd>
 <ul class={tagListClass}>
 {casino.withdrawalMethods.map((item) => (
 <li>{item}</li>
 ))}
 </ul>
 </dd>
 </div>
 ) : null}
 </dl>
 </section>
 ) : null
}

 {
 casino.pros?.length || casino.cons?.length ? (
 <section class="mb-12 grid gap-6 md:grid-cols-2">
 {casino.pros?.length ? (
 <div class="rounded-2xl border border-emerald-200 bg-emerald-50/60 p-6">
 <h2 class="mb-4 text-xl font-bold text-emerald-900">{copy.prosTitle}</h2>
 <ul class="list-inside list-disc space-y-2 text-emerald-950">
 {casino.pros.map((item) => (
 <li>{item}</li>
 ))}
 </ul>
 </div>
 ) : null}
 {casino.cons?.length ? (
 <div class="rounded-2xl border border-rose-200 bg-rose-50/60 p-6">
 <h2 class="mb-4 text-xl font-bold text-rose-900">{copy.consTitle}</h2>
 <ul class="list-inside list-disc space-y-2 text-rose-950">
 {casino.cons.map((item) => (
 <li>{item}</li>
 ))}
 </ul>
 </div>
 ) : null}
 </section>
 ) : null
 }

 {
 casino.playerReview ? (
 <section class="mb-12 rounded-2xl border border-blue-200 bg-white p-6 shadow-sm sm:p-8">
 <h2 class="mb-4 text-2xl font-bold text-gray-900">{copy.playerReviewTitle}</h2>
 <blockquote class="mb-4 text-lg leading-relaxed text-gray-700">
 “{casino.playerReview.description}”
 </blockquote>
 <footer class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-600">
 <span class="font-semibold text-gray-900">{casino.playerReview.personName}</span>
 {casino.playerReview.country ? <span>· {casino.playerReview.country}</span> : null}
 <span>· {casino.playerReview.rating}/10</span>
 <span>· {formatReviewDate(casino.playerReview.date)}</span>
 </footer>
 </section>
 ) : null
 }



 {
 casino.faq?.items.length ? (
 <FaqAccordion
 client:only="react"
 title={casino.faq.title}
 items={casino.faq.items}
 spaceTop={casino.faq.spaceTop ?? 0}
 />
 ) : null
 }
 </div>
 </main>
 <Footer locale={locale} />
</BaseLayout>
