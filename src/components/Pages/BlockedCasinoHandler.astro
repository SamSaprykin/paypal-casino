---
import { BLOCKED_CASINO_MODAL_COPY } from "../../lib/i18n/copies/blocked-casino-modal";
import type { LocaleId } from "../../lib/i18n/locales";

interface Props {
  localeId?: LocaleId;
}

const { localeId = "en-IE" } = Astro.props;
const copy = BLOCKED_CASINO_MODAL_COPY[localeId];
---

<dialog
  id="blocked-casino-modal"
  class="blocked-casino-modal w-[min(100%,32rem)] max-h-[90vh] overflow-y-auto rounded-2xl border border-blue-100 bg-white p-0 shadow-2xl backdrop:bg-slate-900/60 open:animate-in"
  aria-labelledby="blocked-casino-modal-title"
>
  <div class="bg-gradient-to-br from-blue-600 to-blue-800 px-6 py-5 text-white">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-blue-100/90">
          {copy.eyebrow}
        </p>
        <h2 id="blocked-casino-modal-title" class="text-xl font-bold leading-snug text-balance">
          <!-- filled by script -->
        </h2>
      </div>
      <button
        type="button"
        class="blocked-casino-modal-close shrink-0 rounded-lg p-1.5 text-blue-100 transition hover:bg-white/10 hover:text-white"
        aria-label={copy.close}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <div class="p-4 sm:p-5">
    <p class="mb-4 text-sm leading-relaxed text-slate-600">{copy.body}</p>
    <h3 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">
      {copy.alternativesHeading}
    </h3>
    <div id="blocked-casino-modal-alternatives" class="space-y-3">
      <!-- filled by script -->
    </div>
  </div>

  <div class="border-t border-slate-100 px-5 py-4">
    <button
      type="button"
      class="blocked-casino-modal-close w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
    >
      {copy.close}
    </button>
  </div>
</dialog>

<script define:vars={{ modalCopy: copy }}>
  const dialog = document.getElementById("blocked-casino-modal");
  const titleEl = document.getElementById("blocked-casino-modal-title");
  const alternativesEl = document.getElementById("blocked-casino-modal-alternatives");

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function formatRating(rating) {
    if (rating == null || !Number.isFinite(Number(rating))) return null;
    const n = Math.min(5, Math.max(0, Number(rating)));
    const rounded = Math.round(n * 10) / 10;
    return `${rounded % 1 === 0 ? Math.trunc(rounded) : rounded.toFixed(1)}/5`;
  }

  function renderAlternative(alt) {
    const rating = formatRating(alt.rating);
    const logo = alt.logoUrl
      ? `<img src="${escapeHtml(alt.logoUrl)}" alt="" class="h-8 w-16 object-contain" loading="lazy" />`
      : "";
    const bonus = alt.bonusDescription
      ? `<p class="text-xs text-blue-800 font-medium leading-snug">${escapeHtml(alt.bonusDescription)}</p>`
      : "";
    const ratingBadge = rating
      ? `<span class="text-[11px] font-semibold text-blue-700">${escapeHtml(modalCopy.ratingLabel)}: ${rating}</span>`
      : "";

    return `
      <article class="flex flex-col gap-3 rounded-xl border border-blue-100 bg-blue-50/40 p-4 sm:flex-row sm:items-center">
        <div class="flex min-w-0 flex-1 items-center gap-3">
          <div class="flex h-12 w-20 shrink-0 items-center justify-center rounded-lg border border-blue-100 bg-white p-1.5" style="background-color:${escapeHtml(alt.backgroundColor || "#fff")}">
            ${logo}
          </div>
          <div class="min-w-0 space-y-1">
            <h3 class="truncate text-sm font-bold text-slate-900">${escapeHtml(alt.casinoName)}</h3>
            ${bonus}
            ${ratingBadge}
          </div>
        </div>
        <button
          type="button"
          class="blocked-casino-alt-play shrink-0 rounded-lg bg-gradient-to-r from-blue-500 to-blue-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:from-blue-600 hover:to-blue-800"
          data-ref-link="${escapeHtml(alt.referralUrl)}"
          data-casino-name="${escapeHtml(alt.casinoName)}"
        >
          ${escapeHtml(modalCopy.playNow)}
        </button>
      </article>
    `;
  }

  function openBlockedCasinoModal(casinoName, alternatives) {
    if (!dialog || !titleEl || !alternativesEl) return;
    titleEl.textContent = modalCopy.title.replace(/\{\{name\}\}/g, casinoName);
    alternativesEl.innerHTML = (alternatives ?? [])
      .slice(0, 3)
      .map(renderAlternative)
      .join("");
    if (typeof dialog.showModal === "function") {
      dialog.showModal();
    }
  }

  function closeModal() {
    if (dialog && typeof dialog.close === "function") dialog.close();
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const trigger = target.closest("[data-blocked-casino]");
    if (trigger) {
      event.preventDefault();
      const casinoName = trigger.getAttribute("data-casino-name") ?? "This casino";
      let alternatives = [];
      try {
        alternatives = JSON.parse(trigger.getAttribute("data-alternatives") ?? "[]");
      } catch {
        alternatives = [];
      }
      openBlockedCasinoModal(casinoName, alternatives);
      return;
    }

    if (target.closest(".blocked-casino-modal-close")) {
      closeModal();
      return;
    }

    const playBtn = target.closest(".blocked-casino-alt-play");
    if (playBtn) {
      const refLink = playBtn.getAttribute("data-ref-link");
      if (refLink) window.open(refLink, "_blank", "noopener,noreferrer");
    }
  });

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) closeModal();
  });
</script>

<style>
  .blocked-casino-modal::backdrop {
    background: rgb(15 23 42 / 0.55);
    backdrop-filter: blur(2px);
  }
</style>
