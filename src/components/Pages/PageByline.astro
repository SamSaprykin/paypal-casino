---
import { Mail } from "@lucide/astro";
import type { PageAuthorRef } from "../../lib/data/authors";
import type { WebsitePageCopy } from "../../lib/i18n/copies/website-page";

interface Props {
  copy: WebsitePageCopy;
  createdAt?: string;
  updatedAt?: string;
  createdDisplay?: string | null;
  updatedDisplay?: string | null;
  addedBy?: PageAuthorRef;
  reviewedBy?: PageAuthorRef;
}

const {
  copy,
  createdAt,
  updatedAt,
  createdDisplay,
  updatedDisplay,
  addedBy,
  reviewedBy,
} = Astro.props as Props;

const showDates = Boolean(createdAt || updatedAt);
const showAuthors = Boolean(addedBy || reviewedBy);
const show = showDates || showAuthors;

type BylineAuthor = {
  author: PageAuthorRef;
  label: string;
  tone: "blue" | "slate";
};

const bylineAuthors: BylineAuthor[] = [];
if (addedBy) {
  bylineAuthors.push({ author: addedBy, label: copy.addedBy, tone: "blue" });
}
if (reviewedBy) {
  bylineAuthors.push({
    author: reviewedBy,
    label: copy.reviewedBy,
    tone: "slate",
  });
}

function initials(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((p) => p[0]?.toUpperCase() ?? "")
    .join("");
}

function hasContact(author: PageAuthorRef): boolean {
  const social = author.socialLinks;
  return Boolean(
    author.email ||
      social?.linkedin ||
      social?.x ||
      social?.facebook ||
      social?.instagram ||
      (author.externalProfiles && author.externalProfiles.length > 0),
  );
}

const linkClass =
  "inline-flex h-7 w-7 items-center justify-center rounded-md text-slate-500 transition-colors hover:bg-slate-200/80 hover:text-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-blue-500";
---

{
  show ? (
    <div class="flex flex-col gap-3 border-b border-slate-200/70 bg-white/60 px-4 py-3 font-roboto text-xs leading-snug text-slate-600 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
      <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-start sm:gap-x-6 sm:gap-y-3">
        {bylineAuthors.map(({ author, label, tone }) => (
          <div class="flex min-w-0 items-start gap-2.5">
            <div
              class:list={[
                "relative h-9 w-9 shrink-0 overflow-hidden rounded-full",
                tone === "blue"
                  ? "bg-blue-100 text-blue-800"
                  : "bg-slate-200 text-slate-700",
              ]}
            >
              <img
                src={author.image}
                alt=""
                width="36"
                height="36"
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
                onerror="this.classList.add('hidden');var el=this.nextElementSibling;if(el){el.classList.remove('hidden');el.classList.add('flex')}"
              />
              <span
                class="absolute inset-0 hidden items-center justify-center text-[11px] font-bold"
                aria-hidden="true"
              >
                {initials(author.name)}
              </span>
            </div>
            <div class="min-w-0">
              <div class="font-medium text-slate-500">{label}</div>
              <div class="truncate font-semibold text-slate-800">
                {author.name}
              </div>
              {author.role ? (
                <div class="truncate text-slate-500">{author.role}</div>
              ) : null}
              {hasContact(author) ? (
                <div class="mt-1.5 flex flex-wrap items-center gap-0.5">
                  {author.email ? (
                    <a
                      href={`mailto:${author.email}`}
                      class={linkClass}
                      aria-label={`Email ${author.name}`}
                      title={author.email}
                    >
                      <Mail class="h-3.5 w-3.5" aria-hidden="true" />
                    </a>
                  ) : null}
                  {author.socialLinks?.linkedin ? (
                    <a
                      href={author.socialLinks.linkedin}
                      class={linkClass}
                      target="_blank"
                      rel="noopener noreferrer me"
                      aria-label={`${author.name} on LinkedIn`}
                    >
                      <svg
                        class="h-3.5 w-3.5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                      </svg>
                    </a>
                  ) : null}
                  {author.socialLinks?.x ? (
                    <a
                      href={author.socialLinks.x}
                      class={linkClass}
                      target="_blank"
                      rel="noopener noreferrer me"
                      aria-label={`${author.name} on X`}
                    >
                      <svg
                        class="h-3.5 w-3.5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.227-8.451L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z" />
                      </svg>
                    </a>
                  ) : null}
                  {author.socialLinks?.facebook ? (
                    <a
                      href={author.socialLinks.facebook}
                      class={linkClass}
                      target="_blank"
                      rel="noopener noreferrer me"
                      aria-label={`${author.name} on Facebook`}
                    >
                      <svg
                        class="h-3.5 w-3.5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M22 12.07C22 6.48 17.52 2 11.93 2S1.86 6.48 1.86 12.07c0 4.99 3.66 9.13 8.44 9.93v-7.02H7.9v-2.91h2.4V9.84c0-2.37 1.41-3.68 3.57-3.68 1.03 0 2.12.18 2.12.18v2.33h-1.2c-1.18 0-1.55.73-1.55 1.48v1.78h2.64l-.42 2.91h-2.22V22c4.78-.8 8.44-4.94 8.44-9.93z" />
                      </svg>
                    </a>
                  ) : null}
                  {author.socialLinks?.instagram ? (
                    <a
                      href={author.socialLinks.instagram}
                      class={linkClass}
                      target="_blank"
                      rel="noopener noreferrer me"
                      aria-label={`${author.name} on Instagram`}
                    >
                      <svg
                        class="h-3.5 w-3.5"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5zm8.75 1.75a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z" />
                      </svg>
                    </a>
                  ) : null}
                  {author.externalProfiles?.map((profile) => (
                    <a
                      href={profile.url}
                      class="ml-0.5 inline-flex max-w-[7.5rem] truncate rounded-md px-1.5 py-1 text-[10px] font-semibold uppercase tracking-wide text-blue-700 transition-colors hover:bg-blue-50 hover:text-blue-900"
                      target="_blank"
                      rel="noopener noreferrer me"
                      title={profile.label}
                    >
                      {profile.label}
                    </a>
                  ))}
                </div>
              ) : null}
            </div>
          </div>
        ))}
      </div>

      {showDates ? (
        <div class="shrink-0 text-left sm:pt-0.5 sm:text-right">
          {createdAt ? (
            <div>
              <span class="font-medium text-slate-500">{copy.created}</span>{" "}
              <time datetime={createdAt}>{createdDisplay}</time>
            </div>
          ) : null}
          {updatedAt ? (
            <div class:list={{ "mt-1": Boolean(createdAt) }}>
              <span class="font-medium text-slate-500">{copy.updated}</span>{" "}
              <time datetime={updatedAt}>{updatedDisplay}</time>
            </div>
          ) : null}
        </div>
      ) : null}
    </div>
  ) : null
}
